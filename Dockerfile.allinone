# ====================
# Raid Ledger All-In-One Docker Image
# ====================
# Complete stack: PostgreSQL + Redis + API + Nginx
# Usage: docker run -p 80:80 -v raid-ledger-data:/data ghcr.io/sjdodge123/raid-ledger:main
#
# Environment Variables:
#   PORT           - External port (default: 80)
#   ADMIN_PASSWORD - Set a specific admin password on first run (default: random)
#   CORS_ORIGIN    - Allowed CORS origin (default: auto-derived from RENDER_EXTERNAL_URL or localhost)
#
# Data is persisted under /data (PostgreSQL + Redis). Mount a volume to
# retain data across container updates (e.g. Watchtower).
# ====================

# ====================
# Stage 0: glibc runtime donor (for Ollama binary compatibility)
# ====================
# Ollama is compiled against glibc; Alpine uses musl. We copy the glibc
# runtime into /opt/glibc/lib/ so the Ollama binary can be launched with
# the real glibc dynamic linker at runtime.
FROM debian:bookworm-slim AS glibc-donor
RUN apt-get update && apt-get install -y --no-install-recommends libstdc++6 && rm -rf /var/lib/apt/lists/* && \
    mkdir -p /opt/glibc/lib && \
    cp /lib/*-linux-gnu*/libc.so.6 /opt/glibc/lib/ && \
    cp /lib/*-linux-gnu*/libm.so.6 /opt/glibc/lib/ && \
    cp /lib/*-linux-gnu*/libresolv.so.2 /opt/glibc/lib/ && \
    cp /lib/*-linux-gnu*/libgcc_s.so.1 /opt/glibc/lib/ && \
    cp /lib/*-linux-gnu*/libstdc++.so.6 /opt/glibc/lib/ && \
    (cp /lib/*-linux-gnu*/libpthread.so.0 /opt/glibc/lib/ 2>/dev/null || true) && \
    (cp /lib/*-linux-gnu*/libdl.so.2 /opt/glibc/lib/ 2>/dev/null || true) && \
    (cp /lib/*-linux-gnu*/librt.so.1 /opt/glibc/lib/ 2>/dev/null || true) && \
    (cp /lib64/ld-linux-x86-64.so.2 /opt/glibc/lib/ld-linux.so 2>/dev/null || \
     cp /lib/ld-linux-aarch64.so.1 /opt/glibc/lib/ld-linux.so 2>/dev/null) && \
    test -f /opt/glibc/lib/ld-linux.so

# ====================
# Stage 1: Dependencies
# ====================
FROM node:20-alpine AS deps

WORKDIR /app

COPY package*.json ./
COPY api/package*.json ./api/
COPY web/package*.json ./web/
COPY packages/contract/package*.json ./packages/contract/

RUN npm ci

# ====================
# Stage 2: Build
# ====================
FROM deps AS builder

WORKDIR /app

COPY . .

# Build contract, API, and Web
RUN npm run build -w @raid-ledger/contract
RUN npm run build -w @raid-ledger/api
ENV VITE_API_URL=/api
RUN npm run build -w @raid-ledger/web

# ====================
# Stage 3: Production Runtime
# ====================
FROM node:20-alpine AS production

# Install all required services
RUN apk add --no-cache \
  nginx \
  postgresql16 \
  postgresql16-contrib \
  postgresql16-client \
  redis \
  supervisor \
  bash \
  su-exec \
  gettext \
  logrotate \
  zstd

# Build and install pgvector v0.7.4 from source (ROK-948).
# Alpine does not ship a postgresql16-pgvector package, so we compile.
# Build dependencies are installed under a virtual package and removed after
# install to keep the runtime image lean. JIT (clang/llvm) is intentionally
# omitted — pgvector works fine without it and avoids Alpine version drift
# on unversioned clang/llvm package names.
RUN apk add --no-cache --virtual .pgvector-build \
    git build-base postgresql16-dev \
  && git clone --branch v0.7.4 --depth 1 https://github.com/pgvector/pgvector.git /tmp/pgvector \
  && cd /tmp/pgvector \
  && make OPTFLAGS="" PG_CONFIG=/usr/libexec/postgresql16/pg_config \
  && make install PG_CONFIG=/usr/libexec/postgresql16/pg_config \
  && cd / \
  && rm -rf /tmp/pgvector \
  && apk del .pgvector-build

# Copy glibc runtime for Ollama (replaces gcompat which couldn't provide fcntl64)
COPY --from=glibc-donor /opt/glibc/lib/ /opt/glibc/lib/

# Create app user and directories
# Add app user to redis group so API can access Redis Unix socket (ROK-840)
RUN addgroup -g 1001 -S app && \
  adduser -S -D -H -u 1001 -G app app && \
  addgroup app redis

# ROK-1036: Drop nginx worker privileges to app (master stays root for port 80).
# Replaces any existing top-level `user <name>;` directive (commented or not)
# with `user app;`. Appends if absent. Idempotent across rebuilds and across
# whatever stock nginx.conf the alpine `nginx` package ships in future versions.
RUN sed -i 's/^[[:space:]]*#*[[:space:]]*user[[:space:]]\+[a-zA-Z0-9_-]\+;/user app;/' /etc/nginx/nginx.conf && \
    grep -q '^user app;' /etc/nginx/nginx.conf || echo 'user app;' >> /etc/nginx/nginx.conf

WORKDIR /app

# ==================
# Persistent data volume — mount as -v raid-ledger-data:/data
# ==================
RUN mkdir -p /data/postgresql /data/redis /data/backups/daily /data/backups/migrations /data/logs /data/ollama/models /run/postgresql /run/redis && \
  chown -R postgres:postgres /data/postgresql /run/postgresql && \
  chown -R redis:redis /data/redis /run/redis
VOLUME /data

ENV PGDATA=/data/postgresql

# ==================
# Nginx Setup
# ==================
RUN mkdir -p /run/nginx && \
  chown -R app:app /run/nginx /var/lib/nginx /var/log/nginx

# Copy built Web static files
COPY --from=builder /app/web/dist /usr/share/nginx/html

# Nginx config template (port resolved at runtime via envsubst)
COPY nginx/monolith.conf.template /etc/nginx/http.d/default.conf.template

# ROK-1158: security-headers snippet (re-included from static-asset block too).
COPY nginx/snippets/security-headers.conf /etc/nginx/snippets/security-headers.conf

# ==================
# Log Rotation Setup
# ==================
COPY <<'EOF' /etc/logrotate.d/raid-ledger
/data/logs/*.log {
    daily
    rotate 60
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
}
EOF

# ==================
# API Setup
# ==================
COPY --from=builder /app/api/dist ./dist
COPY --from=builder /app/api/package.json ./package.json
COPY --from=builder /app/api/assets ./assets
COPY --from=builder /app/api/src/drizzle/migrations ./drizzle/migrations
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages/contract/dist ./node_modules/@raid-ledger/contract/dist
COPY --from=builder /app/packages/contract/package.json ./node_modules/@raid-ledger/contract/package.json

# Copy seed scripts and data
COPY --from=builder /app/api/dist/scripts ./dist/scripts
COPY --from=builder /app/api/seeds ./dist/seeds

# Bug S Layer 2 (ROK-1326): broad chmod sweep before the runtime drops to
# the `app` user. The Mutagen sync feeding fleet builds occasionally lands
# files at 600 instead of laptop's 644 even with --permissions-mode=manual
# (depends on prior session state and runner-side leftover), which then
# bake into the COPY --from=builder layer with perms that the unprivileged
# `app` user (uid 1001) can't read at runtime — drizzle migrations
# (meta/_journal.json), the JS bundle, seed JSON, static assets. ROK-1325
# (#828) added the same fix on origin/main with the same path list; this
# branch's earlier commit `e961bdba` was a parallel solve. Resolved by
# taking origin/main's path list verbatim. `chmod -R a+rX` adds read for
# everyone plus execute on directories only (capital X), so the hand-
# picked chmod 0755 lines below still control which scripts can be run.
# Idempotent and additive.
RUN chmod -R a+rX ./drizzle/migrations ./dist ./assets ./node_modules ./packages

# Copy entrypoint
COPY api/scripts/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
# Use absolute mode (0755) not `+x`. The Mutagen sync that feeds the
# fleet build context occasionally lands source files at 600 instead of
# the laptop's 644 (perm drift under stress). `chmod +x` on a 600 file
# produces 711 — owner can rwx, group/others can ONLY exec, not READ.
# The Alpine shell then can't open the script to interpret it →
# "permission denied" → restart-loop. 0755 is deterministic.
RUN chmod 0755 /usr/local/bin/docker-entrypoint.sh

# ==================
# Supervisor Config
# ==================
RUN mkdir -p /etc/supervisor.d /etc/supervisor.d/services

# Create all-in-one supervisor config
COPY <<'EOF' /etc/supervisor.d/raid-ledger.ini
[unix_http_server]
file=/run/supervisord.sock
chmod=0700

[supervisorctl]
serverurl=unix:///run/supervisord.sock

[rpcinterface:supervisor]
supervisor.rpcinterface_factory = supervisor.rpcinterface:make_main_rpcinterface

[supervisord]
nodaemon=true
user=root
logfile=/dev/stdout
logfile_maxbytes=0
loglevel=warn
pidfile=/run/supervisord.pid

[program:postgres]
# ROK-1156: pg_stat_statements is preloaded so the extension can capture per-query stats; log_min_duration_statement surfaces any statement slower than 200ms in postgresql.log.
command=/bin/bash -c '/sbin/su-exec postgres /usr/libexec/postgresql16/postgres -D /data/postgresql -c log_min_messages=FATAL -c shared_preload_libraries=pg_stat_statements -c log_min_duration_statement=200ms -c pg_stat_statements.track=all 2>&1 | tee -a /data/logs/postgresql.log'
autostart=true
autorestart=true
priority=10
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
redirect_stderr=true
stopwaitsecs=5
stopsignal=TERM
killasgroup=true
stopasgroup=true

[program:redis]
command=/bin/bash -c '/usr/bin/redis-server --dir /data/redis --daemonize no --port 0 --unixsocket /tmp/redis.sock --unixsocketperm 770 2>&1 | tee -a /data/logs/redis.log'
user=redis
autostart=true
autorestart=true
priority=20
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
redirect_stderr=true
stopwaitsecs=5
stopsignal=TERM

[program:nginx]
command=/bin/bash -c '/usr/sbin/nginx -g "daemon off;" 2>&1 | tee -a /data/logs/nginx.log'
autostart=true
autorestart=true
priority=30
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
redirect_stderr=true

[program:api]
command=/bin/bash -c '/app/start-api.sh 2>&1 | tee -a /data/logs/api.log'
directory=/app
environment=PORT=3000
user=app
autostart=true
autorestart=true
priority=40
startsecs=15
startretries=5
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
redirect_stderr=true

[program:logrotate]
command=/bin/bash -c 'while true; do /usr/sbin/logrotate /etc/logrotate.d/raid-ledger --state /data/logs/.logrotate.state; sleep 86400; done'
autostart=true
autorestart=true
priority=50
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
redirect_stderr=true

[eventlistener:process_events]
command=/app/supervisor-events.sh
events=PROCESS_STATE
buffer_size=100
stderr_logfile=/dev/stderr
stderr_logfile_maxbytes=0

[include]
files = /etc/supervisor.d/services/*.ini
EOF

# Create API startup script (waits for PostgreSQL + Redis)
COPY <<'EOF' /app/start-api.sh
#!/bin/bash
set -e

# ROK-1036: identity + write-permission diagnostic at the very top.
echo "🔒 API running as: $(id)"
echo "   Can write /data/logs:    $(test -w /data/logs    && echo 'yes' || echo 'NO — PERMISSION DENIED')"
echo "   Can write /data/backups: $(test -w /data/backups && echo 'yes' || echo 'NO — PERMISSION DENIED')"
echo "   Can write /data/avatars: $(test -w /data/avatars && echo 'yes' || echo 'NO — PERMISSION DENIED')"
echo "   Can write /data/uploads: $(test -w /data/uploads && echo 'yes' || echo 'NO — PERMISSION DENIED')"
echo "   Redis socket readable:   $(test -r /tmp/redis.sock && echo 'yes' || echo 'not yet / NO')"

# Wait for PostgreSQL to be ready (TCP probe; `app` cannot `su-exec postgres`).
# Probe as the `raid_ledger` role (created by init-db.sh) so `pg_isready` does
# not default to the OS user (`app`), which has no Postgres role.
echo "⏳ Waiting for PostgreSQL..."
until pg_isready -h localhost -U raid_ledger -d raid_ledger -q; do
  sleep 1
done
echo "✅ PostgreSQL is ready"

# Wait for Redis to be ready (Unix socket)
echo "⏳ Waiting for Redis..."
until redis-cli -s /tmp/redis.sock ping > /dev/null 2>&1; do
  sleep 1
done
echo "✅ Redis is ready"

# ── JWT_SECRET resolution (ROK-1035, ROK-1292) ────────────────────
# Priority: 1) env var (must NOT be a known dev default — fail fast)
#           2) /data/.jwt_secret file exists & non-empty → read it
#           3) generate new secret, persist to /data/.jwt_secret
# Known dev defaults rejected by both guards below — keep in sync with
# api/scripts/docker-entrypoint.sh and docker-compose.yml.
HARDCODED_DEFAULTS="raid-ledger-default-secret-change-in-production dev-secret-change-in-prod"

is_known_default() {
  for d in $HARDCODED_DEFAULTS; do
    [ "$1" = "$d" ] && return 0
  done
  return 1
}

# ROK-1292: fail fast if env var is explicitly a known default.
# (Original ROK-1035 code fell through to file/generate which silently
# overwrote JWT_SECRET — the post-resolution guard then checked the *new*
# random value and never fired. Net effect pre-ROK-1292: known-bad env
# var was accepted in practice.)
if [ -n "$JWT_SECRET" ] && is_known_default "$JWT_SECRET"; then
  echo "❌ FATAL: JWT_SECRET is still an insecure hardcoded default ($JWT_SECRET)."
  echo "   Remove the env var override or set a real secret."
  exit 1
fi

if [ -n "$JWT_SECRET" ]; then
  echo "🔑 JWT_SECRET: using explicit env var"
elif [ -s /data/.jwt_secret ]; then
  # ROK-1036: `-s` instead of `-f` because entrypoint.sh pre-touches the
  # file as root + chown to app (the parent /data is root-owned by VOLUME
  # so app cannot create files directly under it). An empty pre-touched
  # file falls through to the generation path.
  export JWT_SECRET=$(cat /data/.jwt_secret)
  echo "🔑 JWT_SECRET: loaded from /data/.jwt_secret"
else
  export JWT_SECRET=$(node -e "console.log(require('crypto').randomBytes(48).toString('base64'))")
  printf '%s' "$JWT_SECRET" > /data/.jwt_secret
  chmod 600 /data/.jwt_secret
  echo "🔑 JWT_SECRET: generated new secret → /data/.jwt_secret"
fi

# Guard: catch a /data/.jwt_secret file that was pre-populated with an
# insecure historical literal (legacy install before ROK-1035).
if is_known_default "$JWT_SECRET"; then
  echo "❌ FATAL: JWT_SECRET loaded from /data/.jwt_secret is an insecure hardcoded default."
  echo "   Delete /data/.jwt_secret and restart to generate a new one."
  exit 1
fi

# Auto-derive CORS_ORIGIN for all-in-one image if not explicitly set.
# Render provides RENDER_EXTERNAL_URL; otherwise keep "auto" so the API
# dynamically allows the request's own origin (works on any hostname).
if [ -z "$CORS_ORIGIN" ]; then
  export CORS_ORIGIN="auto"
fi
if [ "$CORS_ORIGIN" = "auto" ] && [ -n "$RENDER_EXTERNAL_URL" ]; then
  export CORS_ORIGIN="$RENDER_EXTERNAL_URL"
  echo "🌐 CORS_ORIGIN derived from Render: $CORS_ORIGIN"
else
  echo "🌐 CORS_ORIGIN: $CORS_ORIGIN"
fi

# Auto-derive CLIENT_URL from CORS_ORIGIN when not explicitly set.
# The /event plan Discord command and poll embeds need this to generate links.
if [ -z "$CLIENT_URL" ] && [ -n "$CORS_ORIGIN" ] && [ "$CORS_ORIGIN" != "auto" ]; then
  export CLIENT_URL="$CORS_ORIGIN"
  echo "🔗 CLIENT_URL derived from CORS_ORIGIN: $CLIENT_URL"
fi

# Run entrypoint (migrations, admin bootstrap, seeding)
cd /app
exec /usr/local/bin/docker-entrypoint.sh node /app/dist/src/main.js
EOF
RUN chmod 0755 /app/start-api.sh

# Create init script to set up PostgreSQL on first run
COPY <<'EOF' /app/init-db.sh
#!/bin/bash
set -e

# Initialize PostgreSQL if not already done
if [ ! -s "${PGDATA}/PG_VERSION" ]; then
  echo "📦 Initializing PostgreSQL database..."
  /sbin/su-exec postgres initdb -D "${PGDATA}" --auth-local=trust --auth-host=trust > /dev/null 2>&1
  
  # Start PostgreSQL temporarily to create database (quiet LOG-level output)
  /sbin/su-exec postgres pg_ctl -D "${PGDATA}" -o "-k /run/postgresql -c log_min_messages=FATAL" -w start 2>/dev/null

  # Create user and database
  /sbin/su-exec postgres psql -q -c "CREATE USER raid_ledger WITH PASSWORD 'raid_ledger';"
  /sbin/su-exec postgres psql -q -c "CREATE DATABASE raid_ledger OWNER raid_ledger;"
  /sbin/su-exec postgres psql -q -c "GRANT ALL PRIVILEGES ON DATABASE raid_ledger TO raid_ledger;"

  # Enable pgvector extension (ROK-948) — requires superuser, must run before
  # Drizzle migrations create the vector-typed columns.
  /sbin/su-exec postgres psql -q -d raid_ledger -c "CREATE EXTENSION IF NOT EXISTS vector;"

  # Enable pg_stat_statements extension (ROK-1156) — requires superuser and a
  # postgres restart to take effect, but `pg_ctl stop` happens below so the
  # supervisor-managed restart picks up the shared_preload_libraries flag.
  /sbin/su-exec postgres psql -q -d raid_ledger -c "CREATE EXTENSION IF NOT EXISTS pg_stat_statements;"

  # Grant EXECUTE on pg_stat_statements_reset() to raid_ledger (ROK-1333) so
  # the hourly slow-query digest can clear cumulative counters. raid_ledger is
  # intentionally non-superuser (ROK-948 / ROK-1156); pg_read_all_stats alone
  # does NOT confer EXECUTE on this function in PG 16, so the per-function
  # grant is the only path that works.
  /sbin/su-exec postgres psql -q -d raid_ledger -c "GRANT EXECUTE ON FUNCTION pg_stat_statements_reset(oid, oid, bigint) TO raid_ledger;"

  # Stop PostgreSQL (supervisor will start it)
  /sbin/su-exec postgres pg_ctl -D "${PGDATA}" -m fast -w stop 2>/dev/null

  echo "✅ PostgreSQL initialized"
fi
EOF
RUN chmod 0755 /app/init-db.sh

# Supervisor event listener — logs process state changes (ROK-1023)
COPY <<'EOF' /app/supervisor-events.sh
#!/bin/bash
# Supervisor event listener — logs process state changes to /data/logs/
# Protocol: http://supervisord.org/events.html
while true; do
  echo "READY"
  read -r header
  # Extract payload length from header
  len=$(echo "$header" | tr ' ' '\n' | grep '^len:' | cut -d: -f2)
  if [ -n "$len" ] && [ "$len" -gt 0 ]; then
    read -r -n "$len" payload
  else
    payload=""
  fi
  # Log the event
  ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  echo "$ts $header $payload" >> /data/logs/supervisor-events.log
  echo "RESULT 2"
  printf "OK"
done
EOF
RUN chmod 0755 /app/supervisor-events.sh

# Create main entrypoint
COPY <<'EOF' /app/entrypoint.sh
#!/bin/bash
set -e

# Ensure /data subdirectories exist and have correct ownership
# (volume mounts may arrive as root-owned empty dirs)
mkdir -p /data/postgresql /data/redis /data/backups/daily /data/backups/migrations /data/logs /data/ollama/models
chown -R postgres:postgres /data/postgresql
chown -R redis:redis /data/redis

# ROK-1036: prepare app-owned filesystem state. The API now runs as `app`
# (UID 1001) and needs write access to logs, backups, avatars, uploads, and
# the persisted JWT secret. Runs synchronously before supervisord so the
# child processes never observe a half-chowned tree.
mkdir -p /data/logs /data/backups/daily /data/backups/migrations /data/avatars /data/uploads/branding
chown -R app:app /data/logs /data/backups /data/avatars /data/uploads || true

# /data parent must be app-writable so the API can CREATE new files at
# runtime (the ROK-1035 re-encryption sentinel `.jwt_secret_migrated` is
# created by `api/scripts/docker-entrypoint.sh` after the migration runs;
# `app` cannot otherwise add new files because Docker's `VOLUME /data`
# declaration leaves the parent root-owned). Subdirs retain their own
# ownership (postgres/redis/etc — not affected).
chown app:app /data

# ROK-1035 .jwt_secret: pre-touch as root so the existing root:root 600 file
# on upgraded volumes flips to app:app 600 without start-api.sh needing
# parent-directory write permission. chmod 600 matches start-api.sh's
# invariant. The redirect that start-api.sh performs
# (`printf '%s' "$JWT_SECRET" > /data/.jwt_secret`) overwrites the existing
# app-owned file without touching the parent directory.
touch /data/.jwt_secret
chmod 600 /data/.jwt_secret
chown app:app /data/.jwt_secret

# ROK-1035 .jwt_secret_migrated: this is the re-encryption sentinel —
# `docker-entrypoint.sh:32` skips the migration block when the file exists,
# so we MUST NOT pre-create it. Only fix ownership if a previous boot
# already wrote it (pre-ROK-1036 upgrade after ROK-1035 already ran).
[ -e /data/.jwt_secret_migrated ] && chown app:app /data/.jwt_secret_migrated || true

# Log files for supervisor's tee pipelines. Flip api.log + nginx.log to `app`
# so the unprivileged tee can append.
touch /data/logs/api.log /data/logs/nginx.log
chown app:app /data/logs/api.log /data/logs/nginx.log

# Restore log ownership for the postgres/redis programs after the recursive
# chown swept their files to `app`. Touch-and-chown so existing files survive
# unchanged and fresh-install creates an empty file with the right owner.
touch /data/logs/postgresql.log
chown postgres:postgres /data/logs/postgresql.log || true
touch /data/logs/redis.log
chown redis:redis /data/logs/redis.log || true

# Diagnostic block — one `docker logs` look answers "did chown run?".
echo "🔒 PRIVILEGE DROP: filesystem prepared for app (UID 1001)"
echo "   /data/logs          → $(ls -ld /data/logs    | awk '{print $3":"$4}')"
echo "   /data/backups       → $(ls -ld /data/backups | awk '{print $3":"$4}')"
echo "   /data/avatars       → $(ls -ld /data/avatars | awk '{print $3":"$4}')"
echo "   /data/uploads       → $(ls -ld /data/uploads | awk '{print $3":"$4}')"
echo "   .jwt_secret owner   → $(ls -l /data/.jwt_secret 2>/dev/null | awk '{print $3":"$4}' || echo 'not yet created')"
echo "   /tmp/redis.sock     → $(ls -la /tmp/redis.sock 2>/dev/null || echo 'not yet created')"
echo "   app user groups     → $(id app)"

# Initialize database on first run
/app/init-db.sh

# ROK-1036: ensure postgres extensions on existing volumes. init-db.sh handles
# fresh installs; existing volumes (PG_VERSION present) skipped that path and
# start-api.sh can no longer install extensions (it now runs as `app` and
# cannot `su-exec`). Start postgres temporarily on the standard socket path,
# create extensions idempotently, stop cleanly — all before supervisord
# launches `[program:postgres]`.
if [ -s "${PGDATA}/PG_VERSION" ]; then
  echo "🔍 Ensuring postgres extensions (vector, pg_stat_statements) and grants..."
  /sbin/su-exec postgres pg_ctl -D "${PGDATA}" \
    -o "-k /run/postgresql -c log_min_messages=FATAL" -w start
  /sbin/su-exec postgres psql -v ON_ERROR_STOP=1 -qt -d raid_ledger \
    -c "CREATE EXTENSION IF NOT EXISTS vector;" \
    -c "CREATE EXTENSION IF NOT EXISTS pg_stat_statements;" \
    -c "GRANT EXECUTE ON FUNCTION pg_stat_statements_reset(oid, oid, bigint) TO raid_ledger;"
  /sbin/su-exec postgres pg_ctl -D "${PGDATA}" -m fast -w stop
  echo "✅ Extensions and grants ensured"
fi

# Resolve nginx listen port from $PORT (Render injects PORT=10000)
export NGINX_PORT="${PORT:-80}"
envsubst '${NGINX_PORT}' < /etc/nginx/http.d/default.conf.template > /etc/nginx/http.d/default.conf

# Start all services via supervisor
exec supervisord -c /etc/supervisor.d/raid-ledger.ini
EOF
RUN chmod 0755 /app/entrypoint.sh

# ==================
# Environment Defaults
# ==================
ARG COMMIT_SHA=""
ENV COMMIT_SHA=${COMMIT_SHA}
ENV NODE_ENV=production
ENV DATABASE_URL=postgresql://raid_ledger:raid_ledger@localhost:5432/raid_ledger
ENV REDIS_URL=/tmp/redis.sock
ENV DOTENV_CONFIG_QUIET=true
ENV CORS_ORIGIN=auto
ENV CLIENT_URL=
ENV BACKUP_DIR=/data/backups
ENV LOG_DIR=/data/logs
ENV ADMIN_PASSWORD=

# Expose port (nginx)
EXPOSE 80

# Health check
# Use 127.0.0.1 explicitly — Alpine's /etc/hosts maps `localhost` to
# BOTH 127.0.0.1 and ::1, and getent returns ::1 first. nginx in this
# image only listens on IPv4 (`listen 80;` without `listen [::]:80;`),
# so wget on `localhost` got "Connection refused" and the container
# went unhealthy permanently. Detected 2026-05-19 against the rok-1297
# fleet build; the API itself was healthy the whole time.
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://127.0.0.1:${PORT:-80}/api/health/live || exit 1

# Start everything
ENTRYPOINT ["/app/entrypoint.sh"]
