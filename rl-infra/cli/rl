#!/usr/bin/env bash
# rl — local CLI dispatcher for the rl-infra remote test fleet.
#
# Resolves RL_TARGET (auto by default) and dispatches:
#   - remote  → SSH to rl-infra VM, invoke /srv/rl-infra/orchestrator/bin/<cmd>
#   - local   → fall back to existing local-mode scripts (deploy_dev.sh, MCP env lock, validate-ci.sh)
#
# Env vars (set in shell rc):
#   RL_PROXMOX_HOST   default: rl-infra.lan
#   RL_PROXMOX_USER   default: rl
#   RL_TARGET         auto|remote|local  (default: auto)
#   RL_AGENT_ID       auto-derived from $USER + worktree path if unset
set -euo pipefail

RL_PROXMOX_HOST="${RL_PROXMOX_HOST:-rl-infra.lan}"
# User identity:
#   - Default: rl-agent (no sudo, no docker group, Docker API filtered via
#     socket-proxy, infra config files read-only). This is what agents use.
#   - Operator override: export RL_OPERATOR=1 (becomes rl) for ops like
#     `docker compose up -d`, daemon restarts, editing infra config.
#   - Explicit override: export RL_PROXMOX_USER=<user> wins over either.
if [[ -z "${RL_PROXMOX_USER:-}" ]]; then
    if [[ "${RL_OPERATOR:-0}" == "1" ]]; then
        RL_PROXMOX_USER=rl
    else
        RL_PROXMOX_USER=rl-agent
    fi
fi
RL_TARGET="${RL_TARGET:-auto}"

# Find the repo root from the OPERATOR's cwd (not from this script's location —
# rl is typically symlinked into /opt/homebrew/bin or similar, so resolving
# from the script path is wrong). Falls back to empty when not in a git repo.
# Commands that need a repo root (claim, validate-ci) call require_repo_root.
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"

if [[ -z "${RL_AGENT_ID:-}" ]]; then
    # Stable per-worktree id: $USER + sha1 of worktree path (or cwd if no
    # git repo, so the id is still stable per directory).
    RL_AGENT_ID="${USER}-$(printf '%s' "${REPO_ROOT:-$PWD}" | shasum -a 1 | cut -c1-8)"
fi
export RL_AGENT_ID

require_repo_root() {
    if [[ -z "$REPO_ROOT" ]]; then
        echo "[rl] this command must be run from inside the project git repo" >&2
        echo "      cd into ~/Documents/Projects/Raid-Ledger (or your worktree) and retry" >&2
        exit 2
    fi
}

# --- DNS-fallback for RL_PROXMOX_HOST (ROK-1331 M6b HIGH-3) --------------
#
# Agents in sandboxed Claude Code contexts can't always resolve `rl-infra.lan`
# (the operator's Pi-hole provides it on the LAN; sandbox networking doesn't
# forward that). When the candidate host fails to resolve, fall back to the
# literal IP loaded from repo-root .env (`RL_INFRA_IP=192.168.0.132`).
#
# Algorithm:
#   1. Operator explicit override (any non-default host) → echo as-is.
#   2. Otherwise probe with getent (Linux) / dscacheutil (Darwin) / host (any).
#      On probe success → echo $RL_PROXMOX_HOST verbatim.
#   3. Probe fail → walk cwd up to find <repo-root>/.env, parse RL_INFRA_IP,
#      echo that.
#   4. Both fail → echo original $RL_PROXMOX_HOST as best-effort + warn to
#      stderr so downstream SSH errors land in a context the operator can
#      understand.

is_default_host() {
    local h="$1"
    [[ "$h" == "rl-infra" || "$h" == "rl-infra.lan" ]]
}

probe_dns_for_host() {
    local h="$1"
    if command -v getent >/dev/null 2>&1; then
        getent hosts "$h" >/dev/null 2>&1
        return $?
    fi
    if command -v dscacheutil >/dev/null 2>&1; then
        # dscacheutil exits 0 even on no-match, so parse stdout for any
        # `ip_address:` line. Empty stdout → no answer.
        local out
        out=$(dscacheutil -q host -a name "$h" 2>/dev/null)
        if [[ -n "$out" ]] && printf '%s' "$out" | grep -q '^ip_address:'; then
            return 0
        fi
        return 1
    fi
    if command -v host >/dev/null 2>&1; then
        host -W 2 "$h" >/dev/null 2>&1
        return $?
    fi
    # No probe tool available — treat as success; the downstream ssh will
    # surface the real failure if the host doesn't resolve.
    return 0
}

walk_up_for_env_var() {
    local var_name="$1"
    local dir
    dir="$(pwd)"
    local depth=0
    while [[ "$dir" != "/" && $depth -lt 64 ]]; do
        # `.git` is a directory in the main repo and a FILE (gitlink) in a
        # worktree — accept either to handle both layouts.
        if [[ -e "$dir/.git" ]]; then
            if [[ -f "$dir/.env" ]]; then
                local line
                line=$(grep -E "^${var_name}=" "$dir/.env" 2>/dev/null | grep -v '^#' | head -1)
                if [[ -n "$line" ]]; then
                    printf '%s' "${line#*=}"
                fi
            fi
            return 0
        fi
        dir="$(dirname "$dir")"
        depth=$((depth + 1))
    done
}

resolve_proxmox_host() {
    local host="$RL_PROXMOX_HOST"
    if ! is_default_host "$host"; then
        # Explicit operator override — trust it.
        printf '%s\n' "$host"
        return 0
    fi
    if probe_dns_for_host "$host"; then
        printf '%s\n' "$host"
        return 0
    fi
    local fallback_ip
    fallback_ip="$(walk_up_for_env_var RL_INFRA_IP)"
    if [[ -n "$fallback_ip" ]]; then
        printf '%s\n' "$fallback_ip"
        return 0
    fi
    echo "[rl] WARNING: cannot resolve $host and no RL_INFRA_IP in .env — SSH will likely fail" >&2
    printf '%s\n' "$host"
    return 0
}

# Resolve once at module init so every downstream ssh inherits the value.
# The `_resolve_host` subcommand at the dispatch tail prints this verbatim
# for the bash test harness.
RL_PROXMOX_HOST="$(resolve_proxmox_host)"
export RL_PROXMOX_HOST

# --- target resolution ----------------------------------------------------

resolve_target() {
    case "$RL_TARGET" in
        remote|local) echo "$RL_TARGET"; return ;;
        auto) ;;
        *) echo "RL_TARGET must be auto|remote|local (got: $RL_TARGET)" >&2; exit 2 ;;
    esac
    # Use SSH for the probe (not nc) so SSH config aliases like
    # "Host rl-infra" resolve correctly. nc only does direct DNS, but
    # operators usually point RL_PROXMOX_HOST at an ssh-config Host name.
    if ssh -o BatchMode=yes -o ConnectTimeout=3 -o StrictHostKeyChecking=accept-new \
           "${RL_PROXMOX_USER}@${RL_PROXMOX_HOST}" 'true' >/dev/null 2>&1; then
        echo "remote"
    else
        echo "local"
    fi
}

TARGET="$(resolve_target)"

# --- remote dispatch ------------------------------------------------------

# Shell-escape each positional arg for safe interpolation into a string
# that will be re-parsed by the remote login shell. `printf '%q'` emits a
# form bash can re-parse exactly — so a slug, branch, or pass-through arg
# containing `$(...)`, backticks, or quotes is treated as opaque literal
# bytes (H-VM-1). Echoes the escaped, space-joined args.
q_args() {
    local out=""
    local arg
    for arg in "$@"; do
        out+=" $(printf '%q' "$arg")"
    done
    # Strip the leading space so the caller can drop the result mid-string.
    printf '%s' "${out# }"
}

ssh_run() {
    # Pipes RL_AGENT_ID through; orchestrator scripts read it.
    #
    # Callers MUST pass each argv element as a separate positional —
    # `ssh_run claim --branch "$branch"`, NOT a pre-joined string. The
    # remote login shell re-parses whatever string we send, so we
    # printf-%q each arg through q_args. Previously this used "$*" which
    # let any caller arg containing $(...) / backticks / quotes execute
    # arbitrary code as rl-agent on the VM (H-VM-1).
    local remote_cmd
    remote_cmd="RL_AGENT_ID=$(printf '%q' "$RL_AGENT_ID") /srv/rl-infra/orchestrator/bin/$(q_args "$@")"
    ssh -o ConnectTimeout=5 -o BatchMode=yes \
        "${RL_PROXMOX_USER}@${RL_PROXMOX_HOST}" \
        "$remote_cmd"
}

ssh_run_interactive() {
    ssh -t "${RL_PROXMOX_USER}@${RL_PROXMOX_HOST}" "$@"
}

# --- subcommands ----------------------------------------------------------

cmd_claim() {
    require_repo_root
    if [[ "$TARGET" == "local" ]]; then
        echo "[rl] local mode — using MCP env lock instead of remote slot." >&2
        echo "Run: ./scripts/env-lock.sh acquire --purpose '<task>'" >&2
        exit 0
    fi
    # Wait/poll flags. Default: wait up to 10 min, poll every 10s.
    # Pass --no-wait to get a single-shot {queued, position} response.
    local wait=1 timeout=600 interval=10
    local extra_args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --no-wait) wait=0; shift ;;
            --wait-timeout) timeout="$2"; shift 2 ;;
            --poll-interval) interval="$2"; shift 2 ;;
            *) extra_args+=("$1"); shift ;;
        esac
    done
    local branch
    branch="$(git -C "$REPO_ROOT" branch --show-current 2>/dev/null || echo unknown)"

    local started_at deadline now
    started_at=$(date +%s)
    deadline=$((started_at + timeout))

    while true; do
        # Pass each arg as a separate positional so ssh_run can printf-%q
        # them — branch can in principle contain shell metachars (a typo
        # could ship a worktree branch like `foo$(id)`), and any future
        # extra_args from operator typing would too. H-VM-1.
        # `${extra_args[@]:+${extra_args[@]}}` — defensive expansion. Under
        # `set -u`, expanding an empty array via `"${extra_args[@]}"` errors
        # on macOS bash 3.2 ("unbound variable"). The `:+` form expands to
        # the array's elements when non-empty, and to nothing when empty —
        # so the ssh_run call gets the right argv either way. Bug T 2026-05-19.
        RESULT=$(ssh_run claim --branch "$branch" "${extra_args[@]:+${extra_args[@]}}")
        SLOT=$(jq -r '.slot // empty' <<<"$RESULT")
        # ROK-1331 M5a — orchestrator emits both legacy `queued:true` and the
        # new `enqueued:true` during the transition window. Either signals a
        # poll-and-retry response.
        QUEUED=$(jq -r '(.queued // .enqueued // false)' <<<"$RESULT")
        if [[ -n "$SLOT" ]]; then
            echo "$RESULT" | jq .
            # M5a hint surface: inherited envs from a branch-match handoff
            # let the consumer skip its own env deploy. Print only when the
            # field is non-empty so legacy callers don't see noise.
            INH_COUNT=$(jq -r '(.inherited_envs // []) | length' <<<"$RESULT")
            if [[ "$INH_COUNT" != "0" && -n "$INH_COUNT" ]]; then
                echo "[rl] inherited $INH_COUNT env(s) from prior holder (branch match)" >&2
            fi
            ensure_mutagen_sync "$SLOT"
            # ROK-1338 PR-1 fold-in (2026-05-21): block until Mutagen's initial
            # sync round actually completes — `mutagen sync create` (called
            # inside ensure_mutagen_sync) registers the session but returns
            # before files have transferred. Without this flush, downstream
            # commands like `rl_env_build_image_from_runner` start a
            # `docker build /workspace` BEFORE the runner's /workspace has
            # the current files — manifested as a silent 6+ minute hang
            # during ROK-1338 dogfood Phase A. flush_mutagen blocks until
            # the session reports in-sync; if mutagen isn't installed or
            # the session is missing, it no-ops via `|| true` inside.
            flush_mutagen "$SLOT"
            # ROK-1331 M4 AC11: heartbeat must start BEFORE scaffold so a slow
            # remote git fetch doesn't let the claim expire mid-scaffold.
            start_heartbeat_daemon "$SLOT"
            scaffold_runner_git "$SLOT" "$branch"
            # ROK-1326 fix-11: preempt the npm-ci cost on the FIRST
            # validate-ci/test run. Mutagen excludes node_modules so a
            # freshly-claimed slot has none of the workspace's deps
            # available; without this, the first `tsc`/`nest`/`jest`
            # invocation dies with "command not found". Running here at
            # claim time (in the background, doesn't block claim return)
            # moves the cost out of the first agent action and into
            # idle setup time. Skips silently if a prior session left a
            # populated node_modules.
            install_runner_deps "$SLOT" &
            echo
            echo "claimed slot $SLOT"
            echo "  worktree synced to: $(jq -r '.worktree' <<<"$RESULT")"
            echo "  shell:       rl shell"
            echo "  web url:     http://$(jq -r '.hostnames.web' <<<"$RESULT")"
            echo "  debug url:   http://$(jq -r '.hostnames.debug' <<<"$RESULT")"
            return 0
        fi
        if [[ "$QUEUED" != "true" || "$wait" == "0" ]]; then
            echo "$RESULT" | jq .
            return 0
        fi
        now=$(date +%s)
        if (( now >= deadline )); then
            echo "$RESULT" | jq --argjson waited "$((now - started_at))" '. + {wait_timed_out: true, waited_seconds: $waited}'
            return 0
        fi
        local pos len
        # M5a — prefer the new queue_position field, fall back to the legacy
        # `position` for transition-window compat.
        pos=$(jq -r '(.queue_position // .position // "?")' <<<"$RESULT")
        len=$(jq -r '(.queue_length // "?")' <<<"$RESULT")
        echo "[rl] queued at position $pos of $len — polling again in ${interval}s (timeout in $((deadline - now))s)" >&2
        sleep "$interval"
    done
}

cmd_release() {
    if [[ "$TARGET" == "local" ]]; then
        echo "[rl] local mode — releasing MCP env lock." >&2
        ./scripts/env-lock.sh release || true
        exit 0
    fi
    # ROK-1331 M5a — by default an agent release PRESERVES envs (the next
    # claim on the same branch inherits them). Operator path keeps the legacy
    # destroy-everything behavior. Explicit flag overrides win.
    local extra_args=()
    local preserve_flag=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --preserve-envs) preserve_flag="--preserve-envs"; shift ;;
            --destroy-envs)  preserve_flag="--destroy-envs"; shift ;;
            *) extra_args+=("$1"); shift ;;
        esac
    done
    if [[ -z "$preserve_flag" ]]; then
        if [[ "${RL_OPERATOR:-0}" == "1" || "$RL_PROXMOX_USER" == "rl" ]]; then
            preserve_flag="--destroy-envs"
        else
            preserve_flag="--preserve-envs"
        fi
    fi
    # Look up the slot BEFORE the SSH release call drops the claim record,
    # so we know which Mutagen session to terminate. RL_AGENT_ID is
    # printf-%q'd through into the remote jq invocation — defense in
    # depth (today USER + sha1 is always alnum, but the same shape as
    # H-VM-1 — never interpolate user-derived strings into a remote
    # shell context without escaping).
    local slot_for_mutagen
    slot_for_mutagen=$(ssh -o ConnectTimeout=3 -o BatchMode=yes "${RL_PROXMOX_USER}@${RL_PROXMOX_HOST}" \
        "jq -r --arg a $(printf '%q' "$RL_AGENT_ID") '[.[] | select(.agent_id == \$a and .claimed == true) | .slot] | first // empty' /srv/rl-infra/state/claims.json" 2>/dev/null || true)
    stop_heartbeat_daemon
    local result
    result=$(ssh_run release "$preserve_flag" "${extra_args[@]:+${extra_args[@]}}")
    # Compact JSON for parseability by the MCP layer (no trailing pretty-print
    # multi-line output; the result block is already single-line JSON from the
    # orchestrator). Print as-is, no jq reformatting.
    echo "$result"
    # Terminate the Mutagen sync session so the NEXT claim from a possibly
    # different worktree starts with a fresh endpoint. Without this, the
    # session keeps its original source path and ensure_mutagen_sync sees the
    # existing session + no-ops, leaving the runner syncing from the wrong
    # tree. See feedback_rl_fleet_worktree_path.md.
    stop_mutagen_sync "$slot_for_mutagen"
}

# force-release — operator-only: clear a stuck slot regardless of holder.
# Requires RL_OPERATOR=1 in the caller's shell (so the rl CLI SSHes as the
# privileged `rl` user; the orchestrator script also re-checks the gate).
cmd_force_release() {
    [[ "$TARGET" == "local" ]] && { echo "force-release is remote-only" >&2; exit 1; }
    if [[ "${RL_OPERATOR:-0}" != "1" ]]; then
        echo "[rl] force-release requires RL_OPERATOR=1 (export it, then retry)" >&2
        exit 1
    fi
    local slot="" reason="" no_destroy=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --slot) slot="$2"; shift 2 ;;
            --reason) reason="$2"; shift 2 ;;
            --no-destroy) no_destroy="--no-destroy"; shift ;;
            *) echo "unknown arg: $1" >&2; exit 2 ;;
        esac
    done
    [[ -z "$slot" ]] && { echo "usage: rl force-release --slot N [--reason '...'] [--no-destroy]" >&2; exit 2; }
    [[ -z "$reason" ]] && { echo "--reason '<why>' is required (recorded in audit log)" >&2; exit 2; }
    # printf-%q every interpolated value: reason is operator free-form,
    # RL_AGENT_ID derives from $USER, slot/no_destroy are local flags
    # but defense-in-depth (H-VM-1).
    ssh -o ConnectTimeout=5 -o BatchMode=yes "${RL_PROXMOX_USER}@${RL_PROXMOX_HOST}" \
        "RL_OPERATOR=1 RL_FORCE_REASON=$(printf '%q' "$reason") RL_AGENT_ID=$(printf '%q' "$RL_AGENT_ID") \
         /srv/rl-infra/orchestrator/bin/force-release --slot $(printf '%q' "$slot") ${no_destroy}" | jq .
}

cmd_status() {
    if [[ "$TARGET" == "local" ]]; then
        echo "[rl] local mode — running deploy_dev.sh --status"
        "$REPO_ROOT/scripts/deploy_dev.sh" --status
        exit 0
    fi
    # Pass through args so the MCP server (which doesn't pass --pretty) gets
    # parseable JSON, while operator typing `rl status --pretty` gets the
    # human table. Previously hardcoded --pretty here, which broke the MCP
    # rl_status wrapper that expected JSON. Each arg goes through ssh_run's
    # printf-%q for H-VM-1.
    ssh_run status "$@"
}

cmd_shell() {
    [[ "$TARGET" == "local" ]] && { echo "no remote shell in local mode" >&2; exit 1; }
    SLOT=$(ssh_run claim --branch unknown | jq -r '.slot')
    [[ -z "$SLOT" || "$SLOT" == "null" ]] && { echo "no slot claimed — rl claim first (or rl_claim_wait if enqueued)" >&2; exit 1; }
    # SLOT came from jq output of a server-controlled state file; numeric
    # by contract. Still defense-in-depth: validate before interpolating.
    [[ "$SLOT" =~ ^[0-9]+$ ]] || { echo "[rl] unexpected slot value: $SLOT" >&2; exit 1; }
    ssh_run_interactive "docker exec -it rl-runner-$SLOT tmux attach -t main"
}

cmd_env() {
    [[ "$TARGET" == "local" ]] && { echo "env subcommands are remote-only (use deploy_dev.sh locally)" >&2; exit 1; }
    local sub="${1:-}"; shift || true
    case "$sub" in
        # ssh_run takes each arg as a separate positional and printf-%q's
        # them — pass "$@" not "$*" so a slug like `foo$(id)` reaches the
        # remote orchestrator as the literal string. H-VM-1.
        spin)     ssh_run env-spin "$@" | jq . ;;
        destroy)  ssh_run env-destroy "$@" | jq . ;;
        list)     ssh_run status | jq '.envs' ;;
        # ROK-1331 M5a — pin/unpin: defeat (or release) the gc-sweeper's
        # unhealthy-env reaper for a given slug. CLI accepts a positional
        # slug for ergonomics: `rl env pin my-env` rather than --slug=my-env.
        pin|unpin)
            local slug="${1:-}"
            shift || true
            [[ -z "$slug" ]] && { echo "rl env $sub <slug>" >&2; exit 2; }
            [[ "$slug" =~ ^[a-z0-9-]+$ ]] || { echo "slug must match [a-z0-9-]+" >&2; exit 2; }
            ssh_run "env-${sub}" --slug "$slug" | jq .
            ;;
        *) echo "rl env {spin|destroy|list|pin|unpin} [args]" >&2; exit 2 ;;
    esac
}

# ROK-1331 M5a — extend the current claim's expires_at. Holder path doesn't
# need --slot; operator path (RL_OPERATOR=1) MUST pass --slot N.
cmd_extend() {
    [[ "$TARGET" == "local" ]] && { echo "extend is remote-only" >&2; exit 1; }
    local hours=1
    local extra=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --hours) hours="$2"; shift 2 ;;
            --slot)  extra+=(--slot "$2"); shift 2 ;;
            *)
                # First bare arg is treated as hours for ergonomics:
                # `rl extend 4` == `rl extend --hours 4`.
                if [[ "$1" =~ ^[0-9]+$ ]]; then
                    hours="$1"; shift
                else
                    extra+=("$1"); shift
                fi
                ;;
        esac
    done
    ssh_run extend --hours "$hours" "${extra[@]:+${extra[@]}}" | jq .
}

# ROK-1331 M5a — wrappers for the remaining new orchestrator binaries.
cmd_lease_status() {
    [[ "$TARGET" == "local" ]] && { echo "lease-status is remote-only" >&2; exit 1; }
    local extra=()
    [[ -n "${1:-}" && "$1" =~ ^[0-9]+$ ]] && { extra+=(--slot "$1"); shift; }
    ssh_run lease-status "${extra[@]:+${extra[@]}}" | jq .
}

cmd_claim_wait() {
    [[ "$TARGET" == "local" ]] && { echo "claim-wait is remote-only" >&2; exit 1; }
    require_repo_root
    local timeout=600
    local branch
    branch="$(git -C "$REPO_ROOT" branch --show-current 2>/dev/null || echo unknown)"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --timeout) timeout="$2"; shift 2 ;;
            *) shift ;;
        esac
    done
    ssh_run claim-wait --timeout "$timeout" --branch "$branch" | jq .
}

cmd_db() {
    [[ "$TARGET" == "local" ]] && { echo "db is remote-only" >&2; exit 1; }
    local slug="${1:-}"; shift || true
    [[ -z "$slug" ]] && { echo "usage: rl db <slug> [--web]" >&2; exit 2; }
    # CLI-side slug re-validation (H-VM-1). The orchestrator scripts
    # validate `^[a-z0-9-]+$` server-side, but cmd_db here runs
    # `docker exec` DIRECTLY via SSH — no orchestrator binary is invoked
    # in this path, so the orchestrator's regex never gets to see this
    # slug. Without this check a hostile/typo slug like `"; touch /tmp/x; #`
    # reaches the rl-agent shell before any orchestrator validation.
    [[ "$slug" =~ ^[a-z0-9-]+$ ]] || {
        echo "[rl] slug must match [a-z0-9-]+ (got: $(printf '%q' "$slug"))" >&2; exit 2
    }
    if [[ "${1:-}" == "--web" ]]; then
        # Resolve the slot this agent currently holds so the pgweb container
        # carries `rl.role=env` + `rl.slot=N` labels — the same shape the
        # gc-sweeper uses to reap a slot's children on release. Without these,
        # `docker run --rm -d ...` leaves an orphan container that outlives
        # both env-destroy AND slot release (M-VM-6 2026-05-19).
        #
        # NB: env-destroy itself does NOT remove pgweb today — flagged for
        # the orchestrator agent. The sweeper-on-release path closes the gap
        # in the meantime.
        local pgweb_slot
        pgweb_slot=$(current_slot)
        [[ -z "$pgweb_slot" ]] && {
            echo "[rl] no slot claimed — run 'rl claim' (and rl_claim_wait if enqueued) before 'rl db --web'" >&2; exit 1
        }
        [[ "$pgweb_slot" =~ ^[0-9]+$ ]] || {
            echo "[rl] unexpected slot value: $pgweb_slot" >&2; exit 1
        }
        ssh_run_interactive "docker exec -it rl-env-${slug}-pg true && \
            docker run --rm -d --name pgweb-${slug} --network rl-net \
              --label rl.role=env \
              --label rl.slot=${pgweb_slot} \
              --label rl.env_slug=${slug} \
              --label 'traefik.enable=true' \
              --label 'traefik.http.routers.pgweb-${slug}.rule=Host(\`db-${slug}.rl.lan\`)' \
              --label 'traefik.http.services.pgweb-${slug}.loadbalancer.server.port=8081' \
              sosedoff/pgweb --bind=0.0.0.0 --listen=8081 \
              --url postgres://user:password@rl-env-${slug}-pg:5432/raid_ledger?sslmode=disable"
        echo "pgweb up at http://db-${slug}.rl.lan"
    else
        ssh_run_interactive "docker exec -it rl-env-${slug}-pg psql -U user -d raid_ledger"
    fi
}

cmd_logs() {
    [[ "$TARGET" == "local" ]] && { tail -f "$REPO_ROOT"/*.log 2>/dev/null || echo "no local logs"; exit 0; }
    local query="${*:-{rl_role=\"runner\"}}"
    # Open Grafana with the query pre-filled.
    local url="http://grafana.rl.lan/explore?left=$(printf '%s' "[\"now-1h\",\"now\",\"Loki\",{\"expr\":\"$query\"}]" | jq -sRr @uri)"
    case "$(uname -s)" in
        Darwin) open "$url" ;;
        Linux)  xdg-open "$url" ;;
        *) echo "$url" ;;
    esac
}

cmd_validate_ci() {
    require_repo_root
    if [[ "$TARGET" == "local" ]]; then
        exec "$REPO_ROOT/scripts/validate-ci.sh" "$@"
    fi
    # ROK-1336 — opt-in EXIT-trap release. By default the slot persists across
    # `rl validate-ci` exit codes so the agent can ssh in to debug or chain
    # follow-up `rl run-on-runner` calls. Pass --release-on-exit at the front
    # of the arg list for one-shot ergonomics (release fires regardless of
    # success/failure, just like a trap on EXIT).
    local release_on_exit=false
    local forwarded_args=()
    for arg in "$@"; do
        if [[ "$arg" == "--release-on-exit" ]]; then
            release_on_exit=true
        else
            forwarded_args+=("$arg")
        fi
    done
    if [[ "$release_on_exit" == "true" ]]; then
        trap '
            rc=$?
            if [[ -n "${RL_AGENT_ID:-}" ]]; then
                echo "[rl] --release-on-exit: cmd_validate_ci exited rc=$rc, releasing slot" >&2
                cmd_release >/dev/null 2>&1 || true
            fi
        ' EXIT
    fi
    ensure_claim
    # Mutagen pre-flight: make sure the worktree is current before running.
    SLOT=$(current_slot)
    flush_mutagen "$SLOT"
    # Bug R (ROK-1326) defensive re-scaffold: slots claimed BEFORE the
    # cmd_claim scaffold change landed will have a stale or empty .git
    # (mutagen ignore-list now excludes .git entirely). If /workspace/.git/objects
    # is missing, re-scaffold before running validate-ci. Harmless if .git
    # is already healthy — the check exits 0 and no work is done.
    local branch
    branch="$(git -C "$REPO_ROOT" branch --show-current 2>/dev/null || echo main)"
    ensure_runner_git "$SLOT" "$branch"
    # ssh_run printf-%q's each positional. Pass "$@" so a validate-ci flag
    # like --against-env-slug=$(id) reaches the runner as a literal
    # string rather than executing on the VM (H-VM-1).
    ssh_run run-on-runner -- bash /workspace/scripts/validate-ci.sh "${forwarded_args[@]:+${forwarded_args[@]}}"
}

# ROK-1326 fix-7: push-notify pattern. Agents that post a test plan need
# to know when a tester submits without the operator nudging them. The
# Claude Code harness auto-backgrounds Bash invocations and fires a
# task-completion notification when they finish, but MCP tools block the
# agent's main thread for the full call duration (per ROK-1331). Solution:
# expose `rl test-plan wait` as a CLI subcommand so the agent spawns it
# via Bash and gets a harness wake on tester submit.
cmd_test_plan() {
    local sub="${1:-}"
    [[ -z "$sub" ]] && { echo "rl test-plan {wait|status} <slug> [--timeout N]" >&2; exit 2; }
    shift
    case "$sub" in
        wait)   cmd_test_plan_wait "$@" ;;
        status) cmd_test_plan_status "$@" ;;
        *) echo "rl test-plan {wait|status} <slug> [--timeout N]" >&2; exit 2 ;;
    esac
}

cmd_test_plan_wait() {
    local slug="${1:-}"
    [[ -z "$slug" ]] && { echo "rl test-plan wait <slug> [--timeout N]" >&2; exit 2; }
    [[ "$slug" =~ ^[a-z0-9-]+$ ]] || { echo "slug must be [a-z0-9-]+" >&2; exit 2; }
    shift
    local timeout=600
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --timeout) timeout="$2"; shift 2 ;;
            *) echo "unknown arg: $1" >&2; exit 2 ;;
        esac
    done
    # ROK-1326 fix-10 (Codex P1): validate --timeout as a bounded
    # positive integer BEFORE interpolating into the remote shell.
    # Without this, `--timeout '60; rm -rf /'` becomes a command
    # injection on the VM as rl-agent.
    [[ "$timeout" =~ ^[0-9]+$ ]] && (( timeout >= 1 && timeout <= 3600 )) \
        || { echo "invalid --timeout: must be 1..3600 seconds, got: $timeout" >&2; exit 2; }
    if [[ "$TARGET" == "local" ]]; then
        echo "test-plan wait is fleet-only (RL_TARGET=remote)" >&2
        exit 1
    fi
    # Pre-flight: inotifywait MUST be installed on the VM. Without it the
    # ssh below silently exits 127, set +e catches it, the code treats the
    # non-zero rc as "no event = timeout" and emits a fake timed_out JSON.
    # Result: agents think push-notify is working when it's not.
    # Surfaced during ROK-1326 retest 2026-05-19 — same gap affects MCP
    # rl_test_plan_wait and is folded into ROK-1331 follow-ups.
    if ! ssh -o BatchMode=yes -o ConnectTimeout=5 \
        "${RL_PROXMOX_USER}@${RL_PROXMOX_HOST}" \
        "command -v inotifywait >/dev/null 2>&1"; then
        cat <<EOF
{"ok":false,"error":"inotifywait_not_installed","slug":"${slug}","hint":"inotify-tools is required for push-notify. Install on the VM: sudo apt-get install -y inotify-tools"}
EOF
        exit 2
    fi
    # close_write covers tester submit (POST /submit → writePlanAtomic
    # writes a `.<slug>.<ts>.tmp` file then renames it to `<slug>.json`);
    # moved_to covers the rename() landing on the parent dir; delete
    # covers env-destroy reaping the plan. Same event set as the MCP
    # rl_test_plan_wait (ROK-1326 D4).
    #
    # -m (monitor mode) is REQUIRED here. Without it, inotifywait exits
    # after the FIRST event. The dashboard's writePlanAtomic always
    # fires TWO events per submit: close_write on the .tmp file (filename
    # like `.rok-1326-validate.1779226429054.tmp` — doesn't match the
    # slug regex) then moved_to on the final filename (matches). Without
    # -m, inotifywait grabs the .tmp event, dies, the grep -m 1 reads
    # EOF without a match, exits 1, and the CLI mis-reports a timeout
    # that was actually a successful submit. Surfaced during ROK-1326
    # retest 2026-05-19 — operator wait fired in ~2 min instead of 30.
    #
    # With -m: inotifywait keeps streaming events; grep -m 1 reads until
    # the slug-matching filename appears; on match, grep exits 0,
    # SIGPIPE kills inotifywait, ssh exits 0.
    #
    # The remote timeout is enforced via a parent-shell timeout (the
    # `timeout` coreutil) rather than inotifywait's -t flag, because
    # -t and -m are not compatible (-m loops forever; -t is one-shot).
    local plan_re
    plan_re="^${slug}\\.json$"
    # `set -e` at top of file would kill us on the expected non-zero exit
    # from ssh/grep when the timeout fires (no match within window).
    # Disable for the wait + restore immediately.
    local rc=0
    set +e
    ssh -o BatchMode=yes -o ConnectTimeout=5 \
        "${RL_PROXMOX_USER}@${RL_PROXMOX_HOST}" \
        "timeout ${timeout} inotifywait -m -q -e close_write,moved_to,delete --format '%f' /srv/rl-infra/state/test-plans/ 2>/dev/null | grep -m 1 -E '${plan_re}' >/dev/null"
    rc=$?
    set -e
    if (( rc != 0 )); then
        # inotifywait exits 2 on timeout, 1 on other errors. grep -m 1 exits
        # 0 only on a match. So rc != 0 ⇒ no match within timeout.
        echo '{"ok":true,"timed_out":true,"slug":"'"$slug"'","waited_seconds":'"$timeout"'}'
        exit 0
    fi
    # Match landed — emit the current plan JSON so the agent can read
    # verdicts on its next turn (Bash captures stdout into the harness
    # notification).
    ssh -o BatchMode=yes -o ConnectTimeout=5 \
        "${RL_PROXMOX_USER}@${RL_PROXMOX_HOST}" \
        "cat /srv/rl-infra/state/test-plans/${slug}.json"
}

cmd_test_plan_status() {
    local slug="${1:-}"
    [[ -z "$slug" ]] && { echo "rl test-plan status <slug>" >&2; exit 2; }
    [[ "$slug" =~ ^[a-z0-9-]+$ ]] || { echo "slug must be [a-z0-9-]+" >&2; exit 2; }
    if [[ "$TARGET" == "local" ]]; then
        echo "test-plan status is fleet-only (RL_TARGET=remote)" >&2
        exit 1
    fi
    ssh -o BatchMode=yes -o ConnectTimeout=5 \
        "${RL_PROXMOX_USER}@${RL_PROXMOX_HOST}" \
        "cat /srv/rl-infra/state/test-plans/${slug}.json"
}

