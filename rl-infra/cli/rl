# --- helpers --------------------------------------------------------------

current_slot() {
    ssh_run claim --branch unknown | jq -r '.slot // empty'
}

ensure_claim() {
    SLOT=$(current_slot)
    # Use if/fi rather than `[[ -z "$SLOT" ]] && { ... }`. With set -e in
    # effect, the && form makes the function's last command exit with the
    # condition's exit code — which is 1 (false) when SLOT IS set, the
    # successful path. That non-zero return then trips set -e in any
    # caller (e.g. cmd_validate_ci), aborting the script silently before
    # any work is done. Pre-existing on origin/main from PR #827 —
    # surfaced during ROK-1326 fleet validation when `rl validate-ci`
    # exited 1 with no output despite a healthy claim.
    if [[ -z "$SLOT" ]]; then
        echo "no slot — run 'rl claim' first (rl_claim_wait if enqueued)" >&2
        exit 1
    fi
}

ensure_mutagen_sync() {
    local slot="$1"
    local session="rl-slot-$slot"
    if ! command -v mutagen >/dev/null; then
        echo "[rl] mutagen not installed — install from https://mutagen.io/" >&2
        return
    fi
    # CRITICAL: Mutagen lets multiple sessions share the same NAME — only
    # the identifier is unique. If past claim/release cycles leaked orphans
    # (e.g. user-prefix change rl@ → rl-agent@, or stop_mutagen_sync didn't
    # fire), multiple sessions named "rl-slot-N" can race the same source/
    # dest pair and never converge. Count first; if >1 OR if the single
    # one's alpha doesn't match REPO_ROOT, terminate ALL (mutagen sync
    # terminate <name> handles duplicates in one shot) and recreate.
    local count
    # `grep -c` exits 1 when zero matches — which with set -e would abort
    # this function silently right where we MOST want to fall through to
    # the create branch. `|| true` keeps the pipeline's exit at 0; grep -c
    # already prints `0` on no-match so we don't need `echo 0` (which would
    # double the stdout and break `(( count == 1 ))` arithmetic). ROK-1331
    # M4 LOW #6.
    count=$(mutagen sync list 2>/dev/null | grep -c "^Name: $session$" || true)
    if (( count == 1 )); then
        local current_alpha
        current_alpha=$(mutagen sync list "$session" 2>/dev/null \
            | awk '/^Alpha:/{flag=1;next} flag && /URL:/{print $2; exit}')
        if [[ -n "$current_alpha" && "$current_alpha" == "$REPO_ROOT" ]]; then
            # Single session, correct source — reuse.
            return
        fi
        echo "[rl] mutagen session $session points at '$current_alpha', re-creating for '$REPO_ROOT'" >&2
    elif (( count > 1 )); then
        echo "[rl] WARNING: $count duplicate Mutagen sessions named $session — terminating all and recreating" >&2
    fi
    if (( count > 0 )); then
        # `mutagen sync terminate <name>` terminates ALL sessions matching the
        # name in one shot — verified during the bug-fix that motivated this.
        mutagen sync terminate "$session" 2>/dev/null || true
    fi
    # --permissions-mode=manual: Bug S Layer 1 (ROK-1326). Was --permissions-mode=portable
    # which still propagated some macOS xattr-driven perms to the runner as 0600 / 0700
    # and broke Docker COPY in the allinone build. `manual` ignores source perms entirely
    # and forces the explicit defaults below on every beta-side file.
    # --default-{file,directory}-mode-beta force the runner-side perms.
    # --mode=one-way-replica: laptop (alpha) is the SOLE source of truth.
    # Runner (beta) gets aligned to alpha — files that exist only on the
    # runner get DELETED on next sync. Without this (was: default
    # two-way-resolved), any stale files left on a slot's /workspace by
    # a previous session — e.g. operator's main-repo WIP — would
    # propagate UP into the next agent's worktree on their first sync.
    # Reported by the rok-1325 agent 2026-05-19.
    #
    # --ignore: keep this list in sync with rl-infra/mutagen/sync-template.yml.
    # Bug R (ROK-1326): exclude the entire .git tree because cmd_claim
    # scaffolds a fresh shallow .git on the runner side via `git init` +
    # `git fetch origin`. Bug W (ROK-1326): exclude *.tsbuildinfo so tsc
    # incremental caches don't clobber the runner's own build state.
    mutagen sync create \
        --name "$session" \
        --mode=one-way-replica \
        --permissions-mode=manual \
        --default-file-mode-beta=0644 \
        --default-directory-mode-beta=0755 \
        --ignore-vcs=false \
        --ignore=node_modules \
        --ignore='**/node_modules' \
        --ignore=dist \
        --ignore='**/dist' \
        --ignore=coverage \
        --ignore='**/coverage' \
        --ignore='**/coverage/**' \
        --ignore=.git \
        --ignore='.git/**' \
        --ignore=.git/objects \
        --ignore=.git/lfs \
        --ignore='*.tsbuildinfo' \
        --ignore='**/*.tsbuildinfo' \
        --ignore=playwright-report \
        --ignore=test-results \
        --ignore=.rl-perf.log \
        --ignore=.rl-perf.log.errors \
        "$REPO_ROOT" \
        "${RL_PROXMOX_USER}@${RL_PROXMOX_HOST}:/srv/rl-infra/runners/slot-${slot}/worktree"
}

flush_mutagen() {
    local slot="$1"
    command -v mutagen >/dev/null || return 0
    mutagen sync flush "rl-slot-$slot" 2>/dev/null || true
}

# Bug R (ROK-1326): rebuild .git inside the runner container from scratch
# after every claim. The Mutagen sync now ignores .git entirely (so the
# runner never inherits the laptop's local-branch index / packed-refs /
# possibly-corrupt objects directory), and we replace it here with a
# fresh shallow remote-tracking clone. Tools that expect `git` state inside
# /workspace (validate-ci, scripts that detect changed files via `git diff`,
# the install/build steps that read package.json from the staged tree) then
# see a clean repository pinned to the same branch the agent is working on.
#
# Steps run inside the runner container via docker exec, NOT on the VM host:
#   1. rm -rf .git  (handle both file + dir case — was a regular dir before)
#   2. git init -q  (re-create)
#   3. git remote add origin <url>
#   4. git fetch origin main --depth=500 -q
#   5. git reset --mixed FETCH_HEAD  (don't blow away mutagen-synced files)
#   6. git checkout -q -B <branch>   (best-effort; falls back if branch
#                                     doesn't exist remotely — local-only
#                                     branches are legal mid-development)
# ROK-1326 fix-11: preempt `npm ci` so the first validate-ci/test run on
# a freshly-claimed slot doesn't pay the 1-2min dep-install cost on top
# of its own work. Mutagen-excludes node_modules (large + OS-specific
# binaries) so /workspace/node_modules is empty on every fresh claim.
# Runs in the background from cmd_claim — claim returns to the user
# immediately and deps populate while they read the claim output.
# validate-ci.sh has the same guard as a fallback, so a fast follow-up
# run won't hit the missing-tsc failure if this background install
# hasn't finished yet — it'll just inherit the cost there instead.
install_runner_deps() {
    local slot="$1"
    [[ -z "$slot" ]] && return 0
    # `npm ci` is a clean-slate install — faster + more reproducible than
    # `npm install` from a populated state. We skip when node_modules is
    # already populated (prior session, or another concurrent claim
    # finished the install). `2>&1 >/dev/null` keeps the background
    # logging quiet so it doesn't tangle with the claim output the user
    # is reading.
    ssh_run run-on-runner -- bash -c \
        '[ -x /workspace/node_modules/.bin/tsc ] && exit 0; \
         cd /workspace && npm ci --silent --no-audit --no-fund' \
        >/dev/null 2>&1 || true
}

scaffold_runner_git() {
    local slot="$1" branch="$2"
    [[ -z "$slot" ]] && return 0
    local origin_url
    origin_url=$(git -C "$REPO_ROOT" remote get-url origin 2>/dev/null || true)
    if [[ -z "$origin_url" ]]; then
        echo "[rl] no 'origin' remote configured locally — skipping runner .git scaffold" >&2
        return 0
    fi
    [[ -z "$branch" || "$branch" == "unknown" ]] && branch="main"
    # printf-%q every interpolated value: origin_url is a config file value
    # (less risky) but branch can in principle carry shell metachars. Defense
    # in depth (H-VM-1 pattern).
    local quoted_url quoted_branch
    quoted_url=$(printf '%q' "$origin_url")
    quoted_branch=$(printf '%q' "$branch")

    # ROK-1331 M4 AC6 — idempotency probe. If /workspace/.git is already on
    # the target branch AND has objects/pack populated, skip the destructive
    # rebuild (saves 2-5s of remote git work per re-claim of the same slot
    # for the same branch). Detached HEAD or branch mismatch falls through
    # to the rebuild.
    local probe_script
    probe_script=$(cat <<EOF
set -e
cd /workspace 2>/dev/null || exit 1
test -d .git/objects/pack || exit 2
current=\$(git -c safe.directory=/workspace rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
if [[ "\$current" != ${quoted_branch} ]]; then exit 3; fi
ls .git/objects/pack/*.pack >/dev/null 2>&1 || exit 4
exit 0
EOF
)
    if ssh_run run-on-runner -- bash -s <<<"$probe_script" >/dev/null 2>&1; then
        echo "[rl] scaffold-idempotent: slot ${slot} already on ${branch} with packed objects — skipping rebuild" >&2
        return 0
    fi

    local script
    # safe.directory: scaffold runs as root (via run-on-runner) but
    # /workspace is owned by uid 1001 (rl-fleet). Git's dubious-ownership
    # check fires on every operation when uid mismatches the dir owner.
    # The git -c flag scopes the override to this invocation only —
    # cleaner than touching the container's global gitconfig.
    #
    # ROK-1331 M4 AC7 — try fetching the agent's branch first; fall back to
    # main if origin doesn't have it yet (fresh local-only branch). The
    # `|| { warn; return 0; }` outer catch handles "neither branch nor main
    # reachable" without aborting the claim.
    script=$(cat <<EOF
set -e
cd /workspace
rm -rf .git
git -c safe.directory=/workspace init -q
git -c safe.directory=/workspace remote add origin ${quoted_url}
git -c safe.directory=/workspace fetch origin ${quoted_branch} --depth=500 -q 2>/dev/null \\
    || git -c safe.directory=/workspace fetch origin main --depth=500 -q
git -c safe.directory=/workspace reset --mixed FETCH_HEAD
git -c safe.directory=/workspace checkout -q -B ${quoted_branch} 2>/dev/null || true
EOF
)
    # Route through orchestrator's run-on-runner endpoint — rl-agent (the
    # default user) is intentionally NOT in the docker group, so raw
    # `ssh ... docker exec` fails with "permission denied while trying to
    # connect to the docker API". run-on-runner runs as root inside the
    # orchestrator binary, derives the slot from RL_AGENT_ID via _state.sh,
    # and pipes stdin through to `docker exec -i`. Failures here should
    # not be fatal — a slot without .git is still usable for non-git
    # operations.
    ssh_run run-on-runner -- bash -s <<<"$script" >/dev/null 2>&1 || {
        echo "[rl] WARNING: failed to scaffold .git on slot ${slot} — validate-ci will retry" >&2
        return 0
    }
}

# Bug R defensive re-scaffold: only rebuild .git if /workspace/.git/objects
# is missing on the runner. Cheap no-op when .git is healthy. Used by
# cmd_validate_ci so slots claimed before Bug R landed self-heal.
ensure_runner_git() {
    local slot="$1" branch="$2"
    [[ -z "$slot" ]] && return 0
    # Route through run-on-runner same as scaffold_runner_git — direct
    # `docker exec` fails under rl-agent (no docker group membership).
    if ssh_run run-on-runner -- test -d /workspace/.git/objects >/dev/null 2>&1; then
        return 0
    fi
    echo "[rl] runner slot ${slot} missing .git/objects — re-scaffolding" >&2
    scaffold_runner_git "$slot" "$branch"
}

# Terminate the Mutagen sync session for a slot. Called from cmd_release so
# the next claim from a (possibly different) worktree creates a fresh session
# pointing at the new source. Without this, the existing-session-noop in
# ensure_mutagen_sync keeps the OLD source path indefinitely.
#
# Two-tier guard:
#   1. If slot is known (the typical path), terminate by name directly.
#   2. If slot is empty (lookup raced with the release that just cleared the
#      claim — see cmd_release), scan local sessions for any rl-slot-*
#      whose alpha URL matches REPO_ROOT and terminate those. Belt-and-
#      suspenders so an orphan session doesn't outlive the release.
stop_mutagen_sync() {
    local slot="$1"
    command -v mutagen >/dev/null || return 0

    if [[ -n "$slot" ]]; then
        mutagen sync terminate "rl-slot-$slot" 2>/dev/null || true
        return 0
    fi

    [[ -z "$REPO_ROOT" ]] && return 0
    # Scan: find rl-slot-N sessions whose Alpha URL points at our REPO_ROOT.
    # `mutagen sync list` output has alpha/beta blocks per session — match
    # the alpha URL to our local path. Awk groups by Name then captures
    # the alpha URL when present.
    local orphans
    orphans=$(mutagen sync list 2>/dev/null \
        | awk -v root="$REPO_ROOT" '
            /^Name: rl-slot-/ { name = $2; alpha = ""; next }
            /^Alpha:/         { reading_alpha = 1; next }
            /^Beta:/          { reading_alpha = 0; next }
            reading_alpha && /URL:/ && $2 == root { print name }
        ')
    local s
    for s in $orphans; do
        mutagen sync terminate "$s" 2>/dev/null || true
    done
}

start_heartbeat_daemon() {
    local slot="$1"
    local pidfile="$HOME/.rl-heartbeat-${slot}.pid"
    [[ -f "$pidfile" ]] && kill -0 "$(cat "$pidfile")" 2>/dev/null && return
    (
        # CRITICAL: detach all inherited FDs BEFORE the long-running loop
        # starts. Without this, the backgrounded subshell keeps the parent
        # script's stdin/stdout/stderr open — which is fine when invoked
        # interactively, but catastrophic when invoked from the MCP server.
        # The MCP server's execFile/spawn reads from rl claim's stdout pipe (or rl_claim_wait when enqueued)
        # and waits for EOF; the heartbeat subshell inherits that pipe and
        # never closes it, so the MCP call hangs for the full 5-min default
        # timeout. Closing the FDs here lets cmd_claim return cleanly to
        # the MCP caller within milliseconds. Verified 2026-05-18 — every
        # "hung claim" incident tonight traced back to this missing detach.
        exec 0</dev/null 1>/dev/null 2>/dev/null
        # Snapshot RL_AGENT_ID into the subshell with printf-%q so any
        # weird chars (defensive — see deriveAgentId validation in MCP
        # exec.ts) can't break out of the remote shell quoting.
        local quoted_id
        quoted_id=$(printf '%q' "$RL_AGENT_ID")
        while true; do
            ssh -o ConnectTimeout=5 -o BatchMode=yes \
                "${RL_PROXMOX_USER}@${RL_PROXMOX_HOST}" \
                "RL_AGENT_ID=$quoted_id /srv/rl-infra/orchestrator/bin/heartbeat" >/dev/null 2>&1 || true
            sleep 60
        done
    ) &
    disown   # remove from job table so bash doesn't track it through exit
    echo $! > "$pidfile"
}

stop_heartbeat_daemon() {
    for pidfile in "$HOME"/.rl-heartbeat-*.pid; do
        [[ -f "$pidfile" ]] || continue
        kill "$(cat "$pidfile")" 2>/dev/null || true
        rm -f "$pidfile"
    done
}

# --- dispatch -------------------------------------------------------------

usage() {
    cat <<EOF
rl — remote runner CLI (target: $TARGET)

  rl claim [--no-wait] [--wait-timeout N] [--poll-interval N]   # enqueues with queue_position=N when contended
                             acquire a slot (waits + polls if all busy; enqueues with queue_position=N when contended)
  rl release                 release slot + clean up
  rl force-release --slot N --reason '...' [--no-destroy]
                             operator-only: clear stuck slot (requires RL_OPERATOR=1)
  rl status [--pretty]       global view (JSON by default; --pretty for human table)
  rl shell                   tmux attach into your slot
  rl logs [filter]           open Loki/Grafana with filter
  rl env spin <slug>         spin per-env stack (allinone + sibling PG)
  rl env destroy <slug>      tear down env
  rl env list                list active envs
  rl env pin <slug>          pin an env so the sweeper skips it (24h ceiling still applies)
  rl env unpin <slug>        clear the pinned flag
  rl extend [N]              push current claim's expires_at to NOW + N hours (1..24, default 1)
  rl lease-status [N]        snapshot of lease queues + claims + pinned/claimable envs
  rl claim-wait [--timeout N]  long-poll the lease queue: queues until granted (push-notify shape; mirrors rl_claim_wait MCP tool)
  rl db <slug> [--web]       psql or pgweb against env's Postgres
  rl validate-ci [args] [--release-on-exit]
                             run validate-ci.sh inside your runner. The slot
                             persists across exit codes (heartbeat daemon
                             outlives the script) so you can ssh in to debug.
                             Pass --release-on-exit for one-shot ergonomics:
                             the CLI traps EXIT and calls cmd_release on any
                             exit code. Held-but-failed slots are also
                             surfaced via /api/fleet-health
                             (held_slots_with_failed_validate_ci field).
  rl test-plan wait <slug>   long-poll for first tester submit (spawn in background; harness notifies on submit)
  rl test-plan status <slug> cheap one-shot read of the plan JSON
  rl top                     ctop live resource view
  rl gc                      force a sweeper run
  rl snapshot {create|rollback|list} <name>
  rl doctor                  end-to-end health check
EOF
}

case "${1:-}" in
    claim)        shift; cmd_claim "$@" ;;
    claim-wait)   shift; cmd_claim_wait "$@" ;;
    release)      shift; cmd_release "$@" ;;
    force-release) shift; cmd_force_release "$@" ;;
    extend)       shift; cmd_extend "$@" ;;
    lease-status) shift; cmd_lease_status "$@" ;;
    status)       shift; cmd_status "$@" ;;
    shell)        shift; cmd_shell "$@" ;;
    env)          shift; cmd_env "$@" ;;
    db)           shift; cmd_db "$@" ;;
    logs)         shift; cmd_logs "$@" ;;
    validate-ci)  shift; cmd_validate_ci "$@" ;;
    test-plan)    shift; cmd_test_plan "$@" ;;
    top)          shift; cmd_top "$@" ;;
    gc)           shift; cmd_gc "$@" ;;
    snapshot)     shift; cmd_snapshot "$@" ;;
    doctor)       shift; cmd_doctor "$@" ;;
    _resolve_host) printf '%s\n' "$RL_PROXMOX_HOST" ;;
    -h|--help|"") usage ;;
    *) echo "unknown subcommand: $1" >&2; usage >&2; exit 2 ;;
esac
