#!/usr/bin/env bash
# ROK-1331 M4 — env-exec-app <slug> [-e KEY=VAL]... -- <cmd...>
# Wraps `docker exec -i [-e KEY=VAL]... rl-env-<slug>-allinone <cmd...>` so
# rl-agent (no docker group) can run boot/admin scripts inside the env's
# allinone container (e.g. bootstrap-admin.js for sync-local-to-env.sh).
#
# Stdin streams through to docker exec. Stdout/stderr pass through.
# Audit log records slug + argc but NOT -e values (they may carry passwords).
#
# Exit codes:
#   2  bad args / slug regex fail
#   3  allinone container missing
#   *  whatever docker exec returns
set -euo pipefail
BIN_DIR_SELF="$(cd "$(dirname "$0")" && pwd)"
# shellcheck disable=SC1091
source "$BIN_DIR_SELF/_state.sh"

SLUG="${1:-}"
if [[ -z "$SLUG" ]]; then
    echo "usage: env-exec-app <slug> [-e KEY=VAL]... -- <cmd...>" >&2
    exit 2
fi
shift
if ! [[ "$SLUG" =~ ^[a-z0-9-]+$ ]]; then
    echo "slug must be [a-z0-9-]+" >&2
    exit 2
fi

ENV_FLAGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        -e) ENV_FLAGS+=("-e" "$2"); shift 2 ;;
        --) shift; break ;;
        *) break ;;
    esac
done

if [[ $# -eq 0 ]]; then
    echo "env-exec-app: missing command after --" >&2
    exit 2
fi

APP_CONTAINER="rl-env-${SLUG}-allinone"

if ! docker inspect "$APP_CONTAINER" --format '{{.State.Running}}' >/dev/null 2>&1; then
    audit::log env-exec-app not_found "$(jq -nc --arg slug "$SLUG" '{slug:$slug}')" 2>/dev/null || true
    echo "env-exec-app: allinone container '$APP_CONTAINER' not found" >&2
    exit 3
fi

audit::log env-exec-app exec "$(jq -nc --arg slug "$SLUG" --arg argc "$#" '{slug:$slug, argc:$argc}')" 2>/dev/null || true

exec docker exec -i "${ENV_FLAGS[@]:+${ENV_FLAGS[@]}}" "$APP_CONTAINER" "$@"
