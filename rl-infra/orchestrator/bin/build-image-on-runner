#!/usr/bin/env bash
# Build Dockerfile.allinone from the agent's synced /workspace, push to the
# local registry tagged for the calling agent's branch. Used by
# rl_env_build_image_from_runner MCP tool and indirectly by rl_env_deploy.
#
# Required env: RL_AGENT_ID
# Required flags: --tag <tag>     (e.g. "rok-1297" or "feat-foo")
# Optional flags: --no-push       (build only, skip push)
#
# Resolves the agent's slot from claims.json, then runs `docker build`
# inside that runner container. The runner has /var/run/docker.sock
# bind-mounted, so the build uses the host's Docker daemon with
# /workspace (= /srv/rl-infra/runners/slot-N/worktree on the host) as the
# context. Push goes to registry.rl.lan:5000 via the rl-net DNS.
set -euo pipefail
source "$(dirname "$0")/_state.sh"

TAG=""
PUSH=1
while [[ $# -gt 0 ]]; do
    case "$1" in
        --tag) TAG="$2"; shift 2 ;;
        --no-push) PUSH=0; shift ;;
        *) echo "unknown arg: $1" >&2; exit 2 ;;
    esac
done

[[ -z "$TAG" ]] && { echo "--tag <name> required" >&2; exit 2; }
[[ "$TAG" =~ ^[a-zA-Z0-9._-]+$ ]] || { echo "tag must be [a-zA-Z0-9._-]+" >&2; exit 2; }
[[ -z "${RL_AGENT_ID:-}" ]] && { echo "RL_AGENT_ID required" >&2; exit 2; }

SLOT=$(state::slot_for_agent "$RL_AGENT_ID")
[[ -z "$SLOT" ]] && { echo "no slot — run claim first" >&2; exit 2; }

RUNNER="rl-runner-${SLOT}"
FULL_TAG="registry.rl.lan:5000/rl-allinone:${TAG}"

# We build from a TEMP COPY of /workspace inside the runner, not /workspace
# itself, because we apply a workaround patch to Dockerfile.allinone (see
# TECH-DEBT-BACKLOG.md 2026-05-18 — `npm run build -w @raid-ledger/contract`
# emits only .d.ts, web build fails). Patching the source would round-trip
# through Mutagen back to operator's worktree. Once the repo-side fix
# ships, the sed below becomes a no-op (pattern won't match).
PATCH_SED='s|RUN npm run build -w @raid-ledger/contract|RUN cd packages/contract \&\& rm -rf dist *.tsbuildinfo \&\& npx tsc|'
# TECH-DEBT 2026-06-06: drop sync-guard sentinels BEFORE the copy. The guard
# unlinks its laptop-side sentinel after a good probe and Mutagen propagates
# that deletion asynchronously — if it lands mid-`cp -a`, cp dies with
# "cannot stat '/workspace/./.rl-sync-probe-…'" (set -e ⇒ build failed).
# Runner-side deletes are safe: the session is one-way laptop→runner, and a
# file that still exists laptop-side just gets re-created on the next sync.
# Paired with the post-unlink flush in sync-guard.ts (mcp-rl-fleet).
BUILD_CMD="set -e; \
  find /workspace -maxdepth 1 -name '.rl-sync-probe-*' -delete 2>/dev/null || true; \
  TMPDIR=\$(mktemp -d /tmp/rl-build-XXXXXX); \
  cp -a /workspace/. \"\$TMPDIR/\"; \
  cd \"\$TMPDIR\"; \
  sed -i '$PATCH_SED' Dockerfile.allinone; \
  grep -q 'rm -rf dist \*.tsbuildinfo' Dockerfile.allinone || { echo 'PATCH_SED did not match — Dockerfile.allinone source drifted, expected RUN line for @raid-ledger/contract build not found' >&2; exit 3; }; \
  docker build -f Dockerfile.allinone -t '${FULL_TAG}' ."
if [[ "$PUSH" == "1" ]]; then
    BUILD_CMD="${BUILD_CMD} && docker push '${FULL_TAG}'"
fi
BUILD_CMD="${BUILD_CMD}; RC=\$?; rm -rf \"\$TMPDIR\"; exit \$RC"

audit::log build_image started "$(jq -nc --argjson slot "$SLOT" --arg tag "$TAG" '{slot:$slot, tag:$tag}')"

START_TIME=$(date -u +%s)
set +e
docker exec "$RUNNER" bash -c "$BUILD_CMD" >&2
RC=$?
set -e
END_TIME=$(date -u +%s)
DURATION=$(( END_TIME - START_TIME ))

if [[ $RC -ne 0 ]]; then
    audit::log build_image failed "$(jq -nc --argjson slot "$SLOT" --arg tag "$TAG" --argjson rc "$RC" --argjson duration "$DURATION" '{slot:$slot, tag:$tag, rc:$rc, duration_s:$duration}')"
    jq -nc --arg tag "$TAG" --argjson rc "$RC" --argjson duration "$DURATION" \
        '{ok: false, error: "build_failed", tag: $tag, rc: $rc, duration_s: $duration}'
    exit 1
fi

audit::log build_image ok "$(jq -nc --argjson slot "$SLOT" --arg tag "$TAG" --argjson duration "$DURATION" '{slot:$slot, tag:$tag, duration_s:$duration}')"

jq -nc --arg tag "$TAG" --arg full "$FULL_TAG" --argjson slot "$SLOT" --argjson duration "$DURATION" --argjson pushed "$PUSH" \
    '{ok: true, tag: $tag, image: $full, slot: $slot, duration_s: $duration, pushed: ($pushed == 1)}'
