#!/usr/bin/env bash
# ROK-1331 M4 — env-inspect <slug>
# Returns a JSON snapshot of the env's allinone + pg container state via the
# socket-proxy. Used by sync-local-to-env.sh + agents to probe env liveness
# without needing docker-group membership (rl-agent isn't in docker group).
#
# Stdout: single-line JSON. Stderr: error text on failure.
# Exit codes:
#   0  ok
#   1  bad args (missing slug)
#   2  slug regex fail
#   3  container missing (env not found)
#   4  docker error
set -euo pipefail
BIN_DIR_SELF="$(cd "$(dirname "$0")" && pwd)"
# shellcheck disable=SC1091
source "$BIN_DIR_SELF/_state.sh"

SLUG="${1:-}"
if [[ -z "$SLUG" ]]; then
    echo "usage: env-inspect <slug>" >&2
    exit 1
fi
if ! [[ "$SLUG" =~ ^[a-z0-9-]+$ ]]; then
    echo "slug must be [a-z0-9-]+" >&2
    exit 2
fi

APP_CONTAINER="rl-env-${SLUG}-allinone"
PG_CONTAINER="rl-env-${SLUG}-pg"

# Resolve slot from env-registry (preferred — labels can drift on older envs).
SLOT=$(state::query "$RL_ENVS_FILE" --arg slug "$SLUG" \
    '[.[] | select(.slug == $slug) | .slot] | first // empty' 2>/dev/null || true)

# Probe both containers. We treat "missing" as a per-container fact and only
# escalate to exit 3 when BOTH containers are absent (the env doesn't exist).
inspect_status() {
    local container="$1"
    local running status health
    if ! docker inspect "$container" --format '{{.State.Running}}' >/dev/null 2>&1; then
        echo "missing|false|null"
        return 0
    fi
    running=$(docker inspect "$container" --format '{{.State.Running}}' 2>/dev/null || echo "false")
    status=$(docker inspect "$container" --format '{{.State.Status}}' 2>/dev/null || echo "missing")
    health=$(docker inspect "$container" --format '{{.State.Health.Status}}' 2>/dev/null || echo "")
    [[ -z "$health" ]] && health="null"
    echo "${status}|${running}|${health}"
}

APP_RAW=$(inspect_status "$APP_CONTAINER")
PG_RAW=$(inspect_status "$PG_CONTAINER")

IFS='|' read -r APP_STATUS APP_RUNNING APP_HEALTH <<<"$APP_RAW"
IFS='|' read -r PG_STATUS PG_RUNNING _PG_HEALTH <<<"$PG_RAW"

if [[ "$APP_STATUS" == "missing" && "$PG_STATUS" == "missing" ]]; then
    audit::log env-inspect not_found "$(jq -nc --arg slug "$SLUG" '{slug:$slug}')" 2>/dev/null || true
    jq -nc --arg slug "$SLUG" '{ok: false, error: "env_not_found", slug: $slug}'
    exit 3
fi

# Coerce bool/health into JSON-valid tokens.
[[ "$APP_RUNNING" != "true" && "$APP_RUNNING" != "false" ]] && APP_RUNNING="false"
[[ "$PG_RUNNING" != "true" && "$PG_RUNNING" != "false" ]] && PG_RUNNING="false"

if [[ "$APP_HEALTH" == "null" || -z "$APP_HEALTH" ]]; then
    APP_HEALTH_ARG="null"
else
    APP_HEALTH_ARG=$(jq -nc --arg h "$APP_HEALTH" '$h')
fi

SLOT_ARG="null"
if [[ -n "$SLOT" && "$SLOT" =~ ^[0-9]+$ ]]; then
    SLOT_ARG="$SLOT"
fi

OUT=$(jq -nc \
    --arg slug "$SLUG" \
    --argjson slot "$SLOT_ARG" \
    --argjson app_running "$APP_RUNNING" \
    --arg app_status "$APP_STATUS" \
    --argjson app_health "$APP_HEALTH_ARG" \
    --argjson pg_running "$PG_RUNNING" \
    --arg pg_status "$PG_STATUS" \
    '{
        ok: true,
        slug: $slug,
        slot: $slot,
        allinone: {running: $app_running, status: $app_status, health: $app_health},
        pg: {running: $pg_running, status: $pg_status}
    }')

audit::log env-inspect read "$(jq -nc --arg slug "$SLUG" --argjson slot "$SLOT_ARG" '{slug:$slug, slot:$slot}')" 2>/dev/null || true
echo "$OUT"
