#!/usr/bin/env bash
# Spin up a per-env stack: sibling Postgres + allinone container.
# Routed by Traefik via {slug}.rl.lan. Tagged with rl.slot so release sweeps it.
#
# Required env: RL_AGENT_ID
# Required flags: --slug <slug>
# Optional flags: --image <tag>  (default: registry.rl.lan/rl-allinone:latest)
#                 --ttl <hours>  (default: 24)
set -euo pipefail
source "$(dirname "$0")/_state.sh"

SLUG=""
IMAGE="registry.rl.lan:5000/rl-allinone:latest"
TTL_HOURS="${DEFAULT_ENV_TTL_HOURS:-24}"
while [[ $# -gt 0 ]]; do
    case "$1" in
        --slug) SLUG="$2"; shift 2 ;;
        --image) IMAGE="$2"; shift 2 ;;
        --ttl) TTL_HOURS="$2"; shift 2 ;;
        *) echo "unknown arg: $1" >&2; exit 2 ;;
    esac
done

[[ -z "$SLUG" ]] && { echo "--slug required" >&2; exit 2; }
[[ "$SLUG" =~ ^[a-z0-9-]+$ ]] || { echo "slug must be [a-z0-9-]+" >&2; exit 2; }

if [[ -z "${RL_AGENT_ID:-}" ]]; then echo "RL_AGENT_ID required" >&2; exit 2; fi
SLOT=$(state::slot_for_agent "$RL_AGENT_ID")
[[ -z "$SLOT" ]] && { echo "no slot — run claim first" >&2; exit 2; }

NOW=$(date -u +%FT%TZ)
VOL_PG="rl-data-${SLUG}"
NET="rl-net"
PG_CONTAINER="rl-env-${SLUG}-pg"
APP_CONTAINER="rl-env-${SLUG}-allinone"

TRAEFIK_CONF_D="${RL_TRAEFIK_CONF_D:-/srv/rl-infra/traefik/conf.d}"

# Idempotent: if env already exists for this slug, refresh last_touched in
# the state registry (NOT via docker container update --label-add — that flag
# is swarm-mode only and errors on standalone containers). Re-write the
# Traefik conf file too so the route survives state divergence.
if docker inspect "$APP_CONTAINER" >/dev/null 2>&1; then
    state::mutate "$RL_ENVS_FILE" --arg slug "$SLUG" --arg ts "$NOW" \
        'map(if .slug == $slug then .last_touched = $ts else . end)'
    mkdir -p "$TRAEFIK_CONF_D"
    PUBLIC_DOMAIN="${RL_PUBLIC_DOMAIN:-}"
    if [[ -n "$PUBLIC_DOMAIN" ]]; then
        # ${SLUG}test.${PUBLIC_DOMAIN} pattern — keep in sync with non-idempotent path.
        HOST_RULE="Host(\`${SLUG}.rl.lan\`) || Host(\`${SLUG}test.${PUBLIC_DOMAIN}\`)"
    else
        HOST_RULE="Host(\`${SLUG}.rl.lan\`)"
    fi
    cat > "$TRAEFIK_CONF_D/env-${SLUG}.yml" <<EOF
# Generated by env-spin (idempotent path) — do not hand-edit.
http:
  routers:
    env-${SLUG}:
      rule: "${HOST_RULE}"
      service: env-${SLUG}
      entryPoints: [web]
  services:
    env-${SLUG}:
      loadBalancer:
        servers:
          - url: "http://${APP_CONTAINER}:80"
EOF
    # Same primary/internal/public split as the non-idempotent path below.
    IDEM_PUBLIC=""
    if [[ -n "${RL_PUBLIC_DOMAIN:-}" ]]; then
        IDEM_PUBLIC="https://${SLUG}test.${RL_PUBLIC_DOMAIN}"
    fi
    if [[ -n "$IDEM_PUBLIC" ]]; then IDEM_PRIMARY="$IDEM_PUBLIC"; else IDEM_PRIMARY="http://${SLUG}.rl.lan"; fi
    jq -nc --arg slug "$SLUG" --arg url "$IDEM_PRIMARY" \
        --arg internal_url "http://${SLUG}.rl.lan" \
        --arg public_url "$IDEM_PUBLIC" --argjson slot "$SLOT" \
        '{ok: true, idempotent: true, slug: $slug, url: $url, internal_url: $internal_url, public_url: (if $public_url == "" then null else $public_url end), slot: $slot}'
    audit::log env-spin idempotent "$(jq -nc --arg slug "$SLUG" --argjson slot "$SLOT" '{slug:$slug,slot:$slot}')"
    exit 0
fi

# 1. Postgres (per-env, NAS-like).
docker run -d \
    --name "$PG_CONTAINER" \
    --network "$NET" \
    --restart unless-stopped \
    -v "${VOL_PG}:/var/lib/postgresql/data" \
    -e POSTGRES_USER=user \
    -e POSTGRES_PASSWORD=password \
    -e POSTGRES_DB=raid_ledger \
    --label "rl.role=env" \
    --label "rl.env_slug=${SLUG}" \
    --label "rl.slot=${SLOT}" \
    --label "rl.ttl=${TTL_HOURS}h" \
    --label "rl.last_touched=${NOW}" \
    pgvector/pgvector:pg16 >/dev/null

# Wait for postgres ready.
for _ in $(seq 1 30); do
    if docker exec "$PG_CONTAINER" pg_isready -U user -d raid_ledger >/dev/null 2>&1; then break; fi
    sleep 1
done

# 2. Allinone container — built artifacts, prod-like topology.
#
# Note: no traefik.* labels here. Traefik uses file-based config (see
# /srv/rl-infra/traefik/conf.d/). We write the per-env route file below.
#
# When RL_PUBLIC_DOMAIN is set in /srv/rl-infra/.env (e.g.
# "tests.gamernight.net"), pass PUBLIC_URL=https://${SLUG}.${PUBLIC_DOMAIN}
# to the container so the Discord bot and other URL-emitting code reach
# external testers through the operator's reverse proxy. Without that, the
# bot would emit http://{slug}.rl.lan URLs which only work on the LAN.
EXTRA_ENV=()
# When set, env-spin shares the operator's JWT_SECRET with the test env so
# app_settings rows (encrypted with that secret on operator's local DB) will
# decrypt at runtime after rl_env_sync_from_local. Set in /srv/rl-infra/.env:
#   RL_ENV_JWT_SECRET=<paste operator's local JWT_SECRET here>
# Without this, the env's allinone generates its own JWT_SECRET and any
# sync'd app_settings rows will fail to decrypt.
if [[ -n "${RL_ENV_JWT_SECRET:-}" ]]; then
    EXTRA_ENV+=(-e "JWT_SECRET=${RL_ENV_JWT_SECRET}")
fi
PUBLIC_URL_FLAG=()
if [[ -n "${RL_PUBLIC_DOMAIN:-}" ]]; then
    # External hostname pattern: ${SLUG}test.${RL_PUBLIC_DOMAIN}. The literal
    # 'test' suffix on the slug avoids collisions with real subdomains under
    # the operator's apex (raid, plex, status, etc.) so a single-level
    # wildcard `*.${RL_PUBLIC_DOMAIN}` covers all test envs while real
    # services keep their own A records. Set on Cloudflare as `*` (single
    # level), Universal SSL covers it.
    PUBLIC_HOST="${SLUG}test.${RL_PUBLIC_DOMAIN}"
    PUBLIC_URL="https://${PUBLIC_HOST}"
    PUBLIC_URL_FLAG=(
        -e "PUBLIC_URL=${PUBLIC_URL}"
        -e "APP_URL=${PUBLIC_URL}"
        -e "BASE_URL=${PUBLIC_URL}"
        -e "PUBLIC_DOMAIN=${PUBLIC_HOST}"
    )
fi

docker run -d \
    --name "$APP_CONTAINER" \
    --network "$NET" \
    --restart unless-stopped \
    -e DATABASE_URL="postgresql://user:password@${PG_CONTAINER}:5432/raid_ledger" \
    -e DEMO_MODE=true \
    -e NODE_ENV=production \
    "${PUBLIC_URL_FLAG[@]}" \
    "${EXTRA_ENV[@]}" \
    --label "rl.role=env" \
    --label "rl.env_slug=${SLUG}" \
    --label "rl.slot=${SLOT}" \
    --label "rl.ttl=${TTL_HOURS}h" \
    --label "rl.last_touched=${NOW}" \
    "$IMAGE" >/dev/null

# 3. Register the route with Traefik via the file provider.
#    Traefik watches /etc/traefik/conf.d, so a write here triggers a reload.
#
# When RL_PUBLIC_DOMAIN is set (e.g. "tests.gamernight.net"), ALSO accept
# host header {slug}.${RL_PUBLIC_DOMAIN}. The operator's external reverse
# proxy (NPM, Caddy, etc.) forwards external testers to the rl-infra VM,
# and Traefik routes them by the public hostname.
TRAEFIK_CONF_D="${RL_TRAEFIK_CONF_D:-/srv/rl-infra/traefik/conf.d}"
PUBLIC_DOMAIN="${RL_PUBLIC_DOMAIN:-}"
mkdir -p "$TRAEFIK_CONF_D"
if [[ -n "$PUBLIC_DOMAIN" ]]; then
    # ${SLUG}test.${PUBLIC_DOMAIN} pattern — see comment near PUBLIC_URL_FLAG above.
    HOST_RULE="Host(\`${SLUG}.rl.lan\`) || Host(\`${SLUG}test.${PUBLIC_DOMAIN}\`)"
else
    HOST_RULE="Host(\`${SLUG}.rl.lan\`)"
fi
cat > "$TRAEFIK_CONF_D/env-${SLUG}.yml" <<EOF
# Generated by env-spin for env "${SLUG}" — do not hand-edit.
http:
  routers:
    env-${SLUG}:
      rule: "${HOST_RULE}"
      service: env-${SLUG}
      entryPoints: [web]
  services:
    env-${SLUG}:
      loadBalancer:
        servers:
          - url: "http://${APP_CONTAINER}:80"
EOF

# Wait for /health.
URL="http://${APP_CONTAINER}/api/health"
for _ in $(seq 1 60); do
    if docker exec "$APP_CONTAINER" curl -fsS "$URL" >/dev/null 2>&1; then break; fi
    sleep 1
done

# Register.
state::mutate "$RL_ENVS_FILE" \
    --arg slug "$SLUG" --argjson slot "$SLOT" --arg image "$IMAGE" \
    --arg ttl "${TTL_HOURS}h" --arg ts "$NOW" \
    --arg public_domain "${RL_PUBLIC_DOMAIN:-}" \
    '. += [{slug: $slug, slot: $slot, image: $image, ttl: $ttl, created_at: $ts, last_touched: $ts, public_domain: $public_domain}]'

audit::log env-spin ok "$(jq -nc --arg slug "$SLUG" --argjson slot "$SLOT" --arg image "$IMAGE" '{slug:$slug,slot:$slot,image:$image}')"

# Output. When RL_PUBLIC_DOMAIN is set, the EXTERNAL URL is the canonical
# `url` field — that's what agents emit, testers click, operator bookmarks.
# Pi-hole short-circuits *.{RL_PUBLIC_DOMAIN} to the rl-infra VM IP for LAN
# clients (no Cloudflare hop), so external is fast on LAN AND reachable
# off-LAN. The internal http://{slug}.rl.lan URL is kept as `internal_url`
# for fallback (if CF/NPM/internet is down, LAN clients can hit it directly).
PUBLIC_URL_OUT=""
if [[ -n "${RL_PUBLIC_DOMAIN:-}" ]]; then
    PUBLIC_URL_OUT="https://${SLUG}test.${RL_PUBLIC_DOMAIN}"
fi
if [[ -n "$PUBLIC_URL_OUT" ]]; then
    PRIMARY_URL="$PUBLIC_URL_OUT"
else
    PRIMARY_URL="http://${SLUG}.rl.lan"
fi
jq -nc --arg slug "$SLUG" --arg url "$PRIMARY_URL" \
    --arg internal_url "http://${SLUG}.rl.lan" \
    --arg public_url "$PUBLIC_URL_OUT" --argjson slot "$SLOT" \
    '{ok: true, slug: $slug, url: $url, internal_url: $internal_url, public_url: (if $public_url == "" then null else $public_url end), slot: $slot, app_container: "rl-env-\($slug)-allinone", pg_container: "rl-env-\($slug)-pg"}'
