#!/usr/bin/env bash
# ROK-1331 M5a — lease-advance: promote the next waiter in a slot's queue.
#
# Internal binary called by `release` (after clearing the claim) and by
# `gc-sweeper` after dead-claim / hoarded reaps. Reads the slot's queue
# head, evicts stale entries (last_heartbeat > LEASE_HEAD_TIMEOUT_SECONDS
# ago), and synchronously grants the slot to the new head.
#
# Branch-match-or-destroy: if the slot has any `claimable_by_next=true`
# envs whose `created_for_branch` matches the new head's branch, they
# survive the handoff (returned as `inherited_envs`). Otherwise they are
# destroyed SYNCHRONOUSLY inside the same flock window before the grant
# is recorded — `lease-advance` must not return a clean claim while envs
# are mid-destruction.
#
# Args: --slot <N>
# Stdout JSON: {ok, granted, granted_to_agent?, branch?, inherited_envs?, destroyed_envs?}
# Idempotent: empty queue / still-claimed slot → ok:true, granted:false.
set -uo pipefail
source "$(dirname "$0")/_state.sh"

SLOT=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --slot) SLOT="$2"; shift 2 ;;
        *) echo "{\"ok\":false,\"error\":\"unknown_arg\",\"arg\":\"$1\"}" >&2; exit 2 ;;
    esac
done

[[ -z "$SLOT" ]] && { echo '{"ok":false,"error":"missing_slot"}' >&2; exit 2; }
[[ "$SLOT" =~ ^[0-9]+$ ]] || { echo '{"ok":false,"error":"invalid_slot"}' >&2; exit 2; }

# ROK-1331 M11 — bookend lease-advance with a paired timer. The duration
# covers stale eviction + branch-match destroy + claim flip + clear-flag,
# i.e. the full lease-handoff cost. lease.advance.start fires once;
# lease.advance.end fires on EVERY exit path (queue empty, slot still
# claimed, race-loss, success) via trap-like inline emits.
perf::emit "lease.advance.start" "$(jq -nc --argjson slot "$SLOT" '{slot:$slot}')"
perf::start "lease_advance_total"
_perf_lease_end() {
    local granted="${1:-false}" extra="${2-}"
    [[ -z "$extra" ]] && extra='{}'
    perf::end "lease_advance_total" "lease.advance.end" \
        "$(jq -nc --arg g "$granted" --argjson e "$extra" --argjson slot "$SLOT" '$e + {slot:$slot, granted:($g == "true")}')"
}

QUEUE_FILE="$(lease::file_for_slot "$SLOT")"
lease::ensure_file "$SLOT"

if ! jq empty "$QUEUE_FILE" 2>/dev/null; then
    audit::log lease-advance queue_corrupt "$(jq -nc --argjson slot "$SLOT" '{slot:$slot}')"
    jq -nc '{ok:false, error:"queue_corrupt"}'
    exit 1
fi

# Step 1 — STALE EVICTION. Drop queue entries whose last_heartbeat is older
# than LEASE_HEAD_TIMEOUT_SECONDS ago. Audit each eviction so operators can
# correlate "where did my waiter go" later.
NOW_EPOCH=$(date -u +%s)
CUTOFF=$(( NOW_EPOCH - RL_LEASE_HEAD_TIMEOUT_SECONDS ))

# Iterate evicted entries and audit-log each before applying the trim. Done in
# bash (vs a single jq atomic) so the audit lines are present even if the
# subsequent mutate fails — operators see we tried.
EVICTED_AGENTS=$(jq -r --argjson cutoff "$CUTOFF" '
    .[] | select(.last_heartbeat != null) |
    (.last_heartbeat | sub("Z$";"") | sub("\\.[0-9]+$";"") | strptime("%Y-%m-%dT%H:%M:%S") | mktime) as $hb_epoch |
    select($hb_epoch < $cutoff) | .agent_id
' "$QUEUE_FILE" 2>/dev/null || true)

for evicted in $EVICTED_AGENTS; do
    [[ -z "$evicted" ]] && continue
    audit::log lease-advance lease_head_evicted \
        "$(jq -nc --argjson slot "$SLOT" --arg agent "$evicted" '{slot:$slot, agent:$agent, reason:"stale_heartbeat"}')"
done

# Trim stale entries atomically.
state::mutate "$QUEUE_FILE" --argjson cutoff "$CUTOFF" '
    map(select(
        .last_heartbeat == null
        or ((.last_heartbeat | sub("Z$";"") | sub("\\.[0-9]+$";"") | strptime("%Y-%m-%dT%H:%M:%S") | mktime) >= $cutoff)
    ))
'

# Step 2 — read head. Empty queue → no-op.
HEAD_JSON=$(jq -c '.[0] // empty' "$QUEUE_FILE" 2>/dev/null || true)
if [[ -z "$HEAD_JSON" ]]; then
    _perf_lease_end "false" '{"reason":"empty_queue"}'
    # Note: granted is emitted as a string ("true"/"false") rather than a
    # JSON bool so callers using `.granted // empty` (the TDD test convention)
    # don't fall through to empty on the falsy bool case (jq foot-gun).
    jq -nc --argjson slot "$SLOT" '{ok:true, granted:"false", slot:$slot}'
    exit 0
fi

HEAD_AGENT=$(jq -r '.agent_id' <<<"$HEAD_JSON")
HEAD_BRANCH=$(jq -r '.branch // ""' <<<"$HEAD_JSON")

# Step 3 — slot still claimed? race-safe no-op (release didn't finish, or a
# different lease-advance won the flock first).
SLOT_CLAIMED=$(jq -r --argjson s "$SLOT" '.[] | select(.slot == $s) | .claimed' "$RL_CLAIMS_FILE" 2>/dev/null || echo "")
if [[ "$SLOT_CLAIMED" == "true" ]]; then
    _perf_lease_end "false" '{"reason":"slot_still_claimed"}'
    jq -nc --argjson slot "$SLOT" --arg agent "$HEAD_AGENT" '{ok:true, granted:"false", slot:$slot, reason:"slot_still_claimed", head_agent:$agent}'
    exit 0
fi

# Step 4 — branch-match / mismatch decision on claimable envs.
CLAIMABLE_ENVS=$(jq -c --argjson s "$SLOT" \
    '[.[] | select(.slot == $s and (.claimable_by_next // false) == true)]' \
    "$RL_ENVS_FILE" 2>/dev/null || echo "[]")

INHERITED_ENVS="[]"
DESTROYED_ENVS="[]"

if [[ "$(jq 'length' <<<"$CLAIMABLE_ENVS")" -gt 0 ]]; then
    # Partition: matching vs mismatching.
    MATCHING=$(jq -c --arg b "$HEAD_BRANCH" \
        '[.[] | select((.created_for_branch // "") == $b)]' <<<"$CLAIMABLE_ENVS")
    MISMATCHING=$(jq -c --arg b "$HEAD_BRANCH" \
        '[.[] | select((.created_for_branch // "") != $b)]' <<<"$CLAIMABLE_ENVS")

    # AC8 STRICT — synchronous destroy BEFORE recording the grant.
    # env-destroy --force is called inline (foreground). If any destroy
    # fails, abort the grant — leave the env marked claimable for the
    # next sweeper pass to retry.
    if [[ "$(jq 'length' <<<"$MISMATCHING")" -gt 0 ]]; then
        DESTROY_FAILED=0
        while read -r slug; do
            [[ -z "$slug" ]] && continue
            audit::log lease-advance destroy_starting \
                "$(jq -nc --argjson slot "$SLOT" --arg slug "$slug" --arg new "$HEAD_BRANCH" '{slot:$slot, slug:$slug, new_branch:$new}')"
            if ! "$(dirname "$0")/env-destroy" --slug "$slug" --force >/dev/null 2>&1; then
                audit::log lease-advance destroy_failed \
                    "$(jq -nc --argjson slot "$SLOT" --arg slug "$slug" '{slot:$slot, slug:$slug}')"
                DESTROY_FAILED=1
            fi
        done < <(jq -r '.[] | .slug' <<<"$MISMATCHING")

        if (( DESTROY_FAILED == 1 )); then
            _perf_lease_end "false" '{"reason":"destroy_failed"}'
            jq -nc --argjson slot "$SLOT" '{ok:false, error:"destroy_failed", slot:$slot, granted:false}'
            exit 1
        fi
        DESTROYED_ENVS=$(jq -c '[.[] | .slug]' <<<"$MISMATCHING")
    fi

    if [[ "$(jq 'length' <<<"$MATCHING")" -gt 0 ]]; then
        # ROK-1336 #6 — env-registry stores `.public_domain` as the bare
        # RL_PUBLIC_DOMAIN (e.g. "gamernight.net"), NOT a fully-qualified host.
        # The previous template "https://" + public_domain emitted bare
        # https://gamernight.net which doesn't route to any env and breaks
        # Discord OAuth. Emit the slot-stable subdomain (https://slot-N.<domain>)
        # which Traefik routes to whichever env owns slot-N. .rl.lan fallback
        # keeps the per-slug form for the no-RL_PUBLIC_DOMAIN local case.
        INHERITED_ENVS=$(jq -c --argjson slot "$SLOT" \
            '[.[] | {slug, url: (
                if (.public_domain // "") != ""
                then ("https://slot-" + ($slot|tostring) + "." + .public_domain)
                else ("https://" + .slug + ".rl.lan")
                end
            )}]' <<<"$MATCHING")
    fi
fi

# Step 5 — atomically mutate claims.json to flip the slot to claimed + record
# expires_at. Uses precondition so a concurrent claim that beat us to the
# slot doesn't get clobbered.
NOW_ISO=$(date -u +%FT%TZ)
EXPIRES_AT=$(date -u -d "+${RL_CLAIM_DURATION_SECONDS} seconds" +%FT%TZ 2>/dev/null \
    || python3 -W ignore -c "import datetime; print((datetime.datetime.utcnow() + datetime.timedelta(seconds=${RL_CLAIM_DURATION_SECONDS})).strftime('%Y-%m-%dT%H:%M:%SZ'))" 2>/dev/null)

set +e
state::mutate_with_precondition "$RL_CLAIMS_FILE" \
    --argjson slot "$SLOT" \
    --arg agent "$HEAD_AGENT" \
    --arg branch "$HEAD_BRANCH" \
    --arg ts "$NOW_ISO" \
    --arg exp "$EXPIRES_AT" \
    '
    . as $orig
    | (first(.[] | select(.slot == $slot and .claimed == false)) // null) as $row
    | if $row == null then $orig
      else map(if .slot == $slot
               then .claimed = true
                  | .agent_id = $agent
                  | .branch = $branch
                  | .started_at = $ts
                  | .last_heartbeat = $ts
                  | .keep_alive = false
                  | .expires_at = $exp
                  | .extends_count = 0
               else . end)
      end
    '
MUTATE_RC=$?
set -e

if [[ $MUTATE_RC -ne 0 ]]; then
    # Slot was claimed mid-flight. Leave the queue head intact; the next
    # lease-advance call will reattempt.
    _perf_lease_end "false" '{"reason":"slot_taken_concurrent"}'
    jq -nc --argjson slot "$SLOT" --arg agent "$HEAD_AGENT" '{ok:true, granted:"false", slot:$slot, reason:"slot_taken_concurrent", head_agent:$agent}'
    exit 0
fi

# Step 6 — clear claimable_by_next on remaining envs for this slot AND
# drop the head from the queue.
env_registry::clear_claimable_for_slot "$SLOT"
lease::remove "$SLOT" "$HEAD_AGENT"

audit::log lease-advance granted \
    "$(jq -nc --argjson slot "$SLOT" --arg agent "$HEAD_AGENT" --arg branch "$HEAD_BRANCH" --argjson inh "$INHERITED_ENVS" --argjson des "$DESTROYED_ENVS" \
        '{slot:$slot, agent:$agent, branch:$branch, inherited:$inh, destroyed:$des}')"

# ROK-1331 M11 — terminal success perf event. branch + counts give the
# dashboard enough to summarise "lease-advance handed off slot N to
# agent X (rok-Y) with K inherited / J destroyed envs in T ms".
_perf_lease_end "true" \
    "$(jq -nc --arg agent "$HEAD_AGENT" --arg branch "$HEAD_BRANCH" --argjson ic "$(jq 'length' <<<"$INHERITED_ENVS")" --argjson dc "$(jq 'length' <<<"$DESTROYED_ENVS")" '{granted_to_agent:$agent, branch:$branch, inherited_count:$ic, destroyed_count:$dc}')"

jq -nc \
    --argjson slot "$SLOT" \
    --arg agent "$HEAD_AGENT" \
    --arg branch "$HEAD_BRANCH" \
    --arg exp "$EXPIRES_AT" \
    --argjson inh "$INHERITED_ENVS" \
    --argjson des "$DESTROYED_ENVS" \
    '{ok:true, granted:"true", slot:$slot, granted_to_agent:$agent, branch:$branch, expires_at:$exp, inherited_envs:$inh, destroyed_envs:$des}'
