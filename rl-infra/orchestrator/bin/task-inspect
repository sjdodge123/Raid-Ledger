#!/usr/bin/env bash
# ROK-1338 PR-1 — task-inspect
# Usage: task-inspect <task_id>
#
# Forensic reader: prints the full /srv/rl-infra/state/tasks/<task_id>.json
# contents verbatim (no log_tail merging, no elapsed_seconds computation).
# Companion to task-status, which is the agent-friendly summary path.
# Pure read — no flock required.
set -uo pipefail
BIN_DIR_SELF="$(cd "$(dirname "$0")" && pwd)"
# shellcheck disable=SC1091
source "$BIN_DIR_SELF/_state.sh"

if [[ $# -lt 1 ]]; then
    echo '{"ok":false,"error":"missing_task_id"}' >&2
    exit 2
fi
TASK_ID="$1"

if ! [[ "$TASK_ID" =~ ^[a-z0-9]{8,32}$ ]]; then
    echo '{"ok":false,"error":"invalid_task_id"}' >&2
    exit 2
fi

JSON_PATH="$RL_TASKS_DIR/$TASK_ID.json"
if [[ ! -f "$JSON_PATH" ]]; then
    echo '{"ok":false,"error":"not_found"}'
    exit 2
fi

# Emit the file verbatim. Pipe through jq for compactness + validation;
# if the file is corrupt, fall back to raw cat so the caller sees the bytes.
jq -c '.' "$JSON_PATH" 2>/dev/null || cat "$JSON_PATH"
