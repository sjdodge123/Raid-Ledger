#!/usr/bin/env bash
# ROK-1331 M4 — env-psql <slug> [-- <psql-args>...]
# Wraps `docker exec -i rl-env-<slug>-pg psql -U user -d raid_ledger ...`.
# Stdin streams through to psql so `pg_dump | env-psql` works under rl-agent
# (no docker-group membership). Stdout/stderr are psql's; exit code is psql's.
#
# Audit log records slug + argc but NOT the psql args (they may carry secrets
# via COPY FROM stdin).
#
# Exit codes:
#   2  bad args / slug regex fail
#   3  pg container missing
#   *  whatever docker exec returns
set -euo pipefail
BIN_DIR_SELF="$(cd "$(dirname "$0")" && pwd)"
# shellcheck disable=SC1091
source "$BIN_DIR_SELF/_state.sh"

SLUG="${1:-}"
if [[ -z "$SLUG" ]]; then
    echo "usage: env-psql <slug> [-- <psql-args>...]" >&2
    exit 2
fi
shift
# Optional `--` separator before psql args.
if [[ "${1:-}" == "--" ]]; then
    shift
fi
if ! [[ "$SLUG" =~ ^[a-z0-9-]+$ ]]; then
    echo "slug must be [a-z0-9-]+" >&2
    exit 2
fi

PG_CONTAINER="rl-env-${SLUG}-pg"

# Probe container existence — short-circuit with structured error before docker
# exec would surface a less-helpful message.
if ! docker inspect "$PG_CONTAINER" --format '{{.State.Running}}' >/dev/null 2>&1; then
    audit::log env-psql not_found "$(jq -nc --arg slug "$SLUG" '{slug:$slug}')" 2>/dev/null || true
    echo "env-psql: pg container '$PG_CONTAINER' not found" >&2
    exit 3
fi

audit::log env-psql exec "$(jq -nc --arg slug "$SLUG" --arg argc "$#" '{slug:$slug, argc:$argc}')" 2>/dev/null || true

exec docker exec -i "$PG_CONTAINER" psql -U user -d raid_ledger "$@"
