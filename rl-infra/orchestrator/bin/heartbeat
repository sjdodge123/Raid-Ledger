#!/usr/bin/env bash
# Refresh last_heartbeat on the calling agent's claimed slot.
# Required env: RL_AGENT_ID
set -euo pipefail
source "$(dirname "$0")/_state.sh"

if [[ -z "${RL_AGENT_ID:-}" ]]; then
    echo "RL_AGENT_ID required" >&2
    exit 2
fi
SLOT=$(state::slot_for_agent "$RL_AGENT_ID")
if [[ -z "$SLOT" ]]; then
    jq -nc '{ok: false, error: "no_claim"}'
    exit 0
fi
NOW=$(date -u +%FT%TZ)
state::mutate "$RL_CLAIMS_FILE" --arg ts "$NOW" --argjson slot "$SLOT" \
    '(.[] | select(.slot == $slot)) |= (.last_heartbeat = $ts)'
jq -nc --argjson slot "$SLOT" --arg ts "$NOW" '{ok: true, slot: $slot, last_heartbeat: $ts}'
