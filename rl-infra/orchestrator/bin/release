#!/usr/bin/env bash
# Release a runner slot owned by the calling agent.
# Destroys any envs spun by this slot, prunes scoped resources, resets worktree.
#
# Required env: RL_AGENT_ID
# Optional flags: --slot <n>  (forces release of a specific slot — sweeper use)
#                 --force     (skip "is this your slot" check; sweeper use)
set -euo pipefail
source "$(dirname "$0")/_state.sh"

SLOT=""
FORCE=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        --slot) SLOT="$2"; shift 2 ;;
        --force) FORCE=1; shift ;;
        *) echo "unknown arg: $1" >&2; exit 2 ;;
    esac
done

if [[ -z "$SLOT" ]]; then
    if [[ -z "${RL_AGENT_ID:-}" ]]; then
        echo "RL_AGENT_ID required (or pass --slot)" >&2
        exit 2
    fi
    SLOT=$(state::slot_for_agent "$RL_AGENT_ID")
    if [[ -z "$SLOT" ]]; then
        jq -nc '{ok: true, message: "agent holds no slot — noop"}'
        exit 0
    fi
fi

# === ROK-1331 M1: task-cancel cascade — preserve across future rewrites ===
# M5a (Wave 5) will rewrite this script to layer lease-queue advance + the
# --preserve-envs flag on top of the existing teardown flow. The block below
# scans for tasks owned by this slot with status=running and calls task-cancel
# on each so in-flight long-running tools (rl_validate_ci, image builds, etc.)
# don't outlive the slot. M5a MUST keep this block intact as step 0 of release.
# Best-effort — never block release on cancel failure.
# =========================================================================
if [[ -d "$RL_TASKS_DIR" ]]; then
    RUNNING_TASKS=$(jq -r --argjson slot "$SLOT" \
        'select(.slot == $slot and .status == "running") | .task_id' \
        "$RL_TASKS_DIR"/*.json 2>/dev/null || true)
    for tid in $RUNNING_TASKS; do
        [[ -z "$tid" ]] && continue
        "$(dirname "$0")/task-cancel" "$tid" "slot_released" >/dev/null 2>&1 || true
    done
fi

# Tear down envs spun by this slot.
ENV_SLUGS=$(docker ps -a --filter "label=rl.slot=$SLOT" --filter "label=rl.role=env" --format '{{.Label "rl.env_slug"}}' | sort -u)
for slug in $ENV_SLUGS; do
    [[ -z "$slug" ]] && continue
    "$(dirname "$0")/env-destroy" --slug "$slug" --force >/dev/null || true
done

# Scoped prune: belt-and-suspenders for any container/image tagged with
# this slot that env-destroy didn't catch. Both stdout AND stderr suppressed
# because the socket-proxy blocks prune endpoints entirely (intended) and
# the "Forbidden" noise is misleading — env-destroy already does the real
# work via targeted docker rm.
docker container prune -f --filter "label=rl.slot=$SLOT" >/dev/null 2>&1 || true
docker image prune -f --filter "label=rl.slot=$SLOT" >/dev/null 2>&1 || true

# Drop the claim record.
state::mutate "$RL_CLAIMS_FILE" --argjson slot "$SLOT" \
    '(.[] | select(.slot == $slot)) |= (.claimed = false | .agent_id = null | .branch = null | .started_at = null | .last_heartbeat = null)'

# H-VM-4: Also remove ourselves from the queue. force-release does this
# for the displaced agent specifically, but normal release didn't — so
# any agent who queued itself before claiming (retried `rl claim` while
# still queued from a previous attempt) leaves a stale queue entry that
# blocks waiters behind it until QUEUE_TTL=1800s. queue::remove is
# idempotent (no-op if not queued). Only meaningful when we know the
# agent id — i.e. in the non-sweeper path. Sweeper invocations pass
# --slot --force without RL_AGENT_ID set; skip then.
if [[ -n "${RL_AGENT_ID:-}" ]]; then
    queue::remove "$RL_AGENT_ID"
fi

audit::log release ok "$(jq -nc --argjson slot "$SLOT" --argjson force "$FORCE" '{slot: $slot, force: ($force == 1)}')"

# jq -n with --slurp gives null input that split() can't handle. Pipe the
# slug list through jq with -R (raw input) and --slurp (collect into one
# string), THEN split by newlines, dropping empties.
ENVS_JSON=$(printf '%s' "$ENV_SLUGS" | jq -Rc --slurp 'split("\n") | map(select(length>0))')
jq -nc --argjson slot "$SLOT" --argjson envs "$ENVS_JSON" \
    '{ok: true, slot: $slot, destroyed_envs: $envs}'
