#!/usr/bin/env bash
# Destroy a per-env stack and its volume.
#
# Required flags: --slug <slug>
# Optional flags: --force   (skip "is this your env" check; sweeper use)
set -euo pipefail
source "$(dirname "$0")/_state.sh"

SLUG=""
FORCE=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        --slug) SLUG="$2"; shift 2 ;;
        --force) FORCE=1; shift ;;
        *) echo "unknown arg: $1" >&2; exit 2 ;;
    esac
done

[[ -z "$SLUG" ]] && { echo "--slug required" >&2; exit 2; }

# ROK-1331 M11 — bookend env-destroy with paired timer so dashboards can
# spot "env-destroy of slug X took 18s" outliers (Postgres volume rm on a
# slow disk is the most common cause).
perf::emit "env.destroy.start" "$(jq -nc --arg slug "$SLUG" --argjson force "$FORCE" '{slug:$slug, force:($force == 1)}')"
perf::start "env_destroy_total"

PG_CONTAINER="rl-env-${SLUG}-pg"
APP_CONTAINER="rl-env-${SLUG}-allinone"
PGWEB_CONTAINER="pgweb-${SLUG}"
VOL_PG="rl-data-${SLUG}"

# Ownership check unless --force.
if [[ $FORCE -eq 0 ]]; then
    if [[ -z "${RL_AGENT_ID:-}" ]]; then echo "RL_AGENT_ID required (or pass --force)" >&2; exit 2; fi
    EXPECTED_SLOT=$(state::slot_for_agent "$RL_AGENT_ID")
    ACTUAL_SLOT=$(docker inspect "$APP_CONTAINER" --format '{{ index .Config.Labels "rl.slot" }}' 2>/dev/null || echo "")
    if [[ -n "$ACTUAL_SLOT" && "$ACTUAL_SLOT" != "$EXPECTED_SLOT" ]]; then
        echo "env $SLUG owned by slot $ACTUAL_SLOT, you hold slot $EXPECTED_SLOT (use --force to override)" >&2
        exit 1
    fi
fi

# HO-1 (ROK-1326): record the destroyed env's slot BEFORE we wipe state so the
# slot-rule re-registration below knows which slot to scan for surviving envs.
DESTROYED_SLOT=$(state::query "$RL_ENVS_FILE" --arg slug "$SLUG" \
    '[.[] | select(.slug == $slug) | .slot] | first // empty')

for c in "$APP_CONTAINER" "$PG_CONTAINER"; do
    docker rm -f "$c" >/dev/null 2>&1 || true
done
# HO-1 (ROK-1326): pgweb container is spawned per-slug by `rl db <slug> --web`
# and labelled rl.role=env / rl.env_slug=<slug>. env-destroy previously left
# it as an orphan that outlived the env-destroy call AND the slot release;
# the gc-sweeper would eventually reap it on release but until then port
# 8081 inside rl-net was held. Reap explicitly here so destroy is hermetic.
docker rm -f "$PGWEB_CONTAINER" >/dev/null 2>&1 || true
docker volume rm "$VOL_PG" >/dev/null 2>&1 || true

# Remove the Traefik conf file so the route disappears (Traefik watches the
# dir and auto-reloads). Without this, the host would still resolve via the
# wildcard DNS but Traefik would 502 because the upstream container is gone.
TRAEFIK_CONF_D="${RL_TRAEFIK_CONF_D:-/srv/rl-infra/traefik/conf.d}"
DESTROYED_CONF="$TRAEFIK_CONF_D/env-${SLUG}.yml"
# HO-5 (ROK-1326): if this env owned the slot-N.${RL_PUBLIC_DOMAIN} Traefik
# rule (Discord OAuth callback hostname), re-register the rule on the
# next-oldest surviving env in the same slot BEFORE we delete the owner's
# conf file. Without this, the OAuth URL 502s until the next env-spin on
# that slot — which can be hours or a full operator-driven re-deploy away.
PUBLIC_DOMAIN="${RL_PUBLIC_DOMAIN:-}"
if [[ -n "$PUBLIC_DOMAIN" && -n "$DESTROYED_SLOT" && -f "$DESTROYED_CONF" ]]; then
    # Owner check: does the destroyed env's conf carry the slot Host rule?
    if grep -qE "^[[:space:]]*rule:.*Host\(\`slot-${DESTROYED_SLOT}\.${PUBLIC_DOMAIN}\`\)" \
            "$DESTROYED_CONF" 2>/dev/null; then
        # Find the next-oldest surviving env on the same slot. Excludes
        # the slug being destroyed. Sort by created_at ascending. `-r`
        # so the captured slug doesn't carry the JSON-string double-quotes.
        SUCCESSOR_SLUG=$(state::query "$RL_ENVS_FILE" -r \
            --arg slug "$SLUG" --argjson slot "$DESTROYED_SLOT" \
            '[.[] | select(.slot == $slot and .slug != $slug)]
             | sort_by(.created_at)
             | first
             | .slug // empty')
        if [[ -n "$SUCCESSOR_SLUG" ]]; then
            SUCCESSOR_CONF="$TRAEFIK_CONF_D/env-${SUCCESSOR_SLUG}.yml"
            SUCCESSOR_APP_CONTAINER="rl-env-${SUCCESSOR_SLUG}-allinone"
            # Liveness probe — if the successor's allinone isn't running we
            # MUST NOT re-register the slot route. Pointing the slot URL at
            # a stopped container 502s every OAuth callback until next
            # env-spin. Skip-and-log instead so the dead-route is visible.
            SUCC_RUNNING=$(docker inspect "$SUCCESSOR_APP_CONTAINER" \
                --format '{{.State.Running}}' 2>/dev/null || echo "")
            if [[ "$SUCC_RUNNING" != "true" ]]; then
                audit::log env-destroy slot-rule-skip-dead-successor \
                    "$(jq -nc --arg from "$SLUG" --arg to "$SUCCESSOR_SLUG" \
                        --argjson slot "$DESTROYED_SLOT" \
                        --arg running "$SUCC_RUNNING" \
                        '{from:$from, to:$to, slot:$slot, successor_running:$running}')"
            elif [[ -f "$SUCCESSOR_CONF" ]]; then
                NEW_HOST_RULE="Host(\`${SUCCESSOR_SLUG}.rl.lan\`) || Host(\`${SUCCESSOR_SLUG}test.${PUBLIC_DOMAIN}\`) || Host(\`slot-${DESTROYED_SLOT}.${PUBLIC_DOMAIN}\`)"
                # Slot-scoped flock to keep parallel env-spin + env-destroy
                # from racing the slot's conf files (mirrors the env-spin
                # serialization pattern). 5s timeout — never wait silently.
                SLOT_LOCK_FILE="${TRAEFIK_CONF_D}/.slot-${DESTROYED_SLOT}.lock"
                : > "$SLOT_LOCK_FILE" 2>/dev/null || true
                exec 9>"$SLOT_LOCK_FILE"
                if ! flock -w 5 9 2>/dev/null; then
                    audit::log env-destroy flock-warning \
                        "$(jq -nc --arg slot "$DESTROYED_SLOT" \
                            '{slot:$slot, msg:"slot-rule reassignment proceeding without lock"}')"
                fi
                # Conf merge: prefer in-place rule-line replacement so the
                # successor's middlewares / tls / custom headers survive.
                # Full-overwrite is only a fallback for anomalous confs that
                # lack any `rule:` line (e.g. conf-not-managed-by-orchestrator).
                if grep -qE '^[[:space:]]*rule:.*Host\(' "$SUCCESSOR_CONF"; then
                    SUCCESSOR_CONF_TMP="${SUCCESSOR_CONF}.tmp.$$"
                    NEW_HOST_RULE_ESC="$NEW_HOST_RULE" \
                        awk '
                            $0 ~ /^[[:space:]]*rule:.*Host\(/ && !done {
                                match($0, /^[[:space:]]*/)
                                indent = substr($0, RSTART, RLENGTH)
                                printf "%srule: \"%s\"\n", indent, ENVIRON["NEW_HOST_RULE_ESC"]
                                done = 1
                                next
                            }
                            { print }
                        ' "$SUCCESSOR_CONF" > "$SUCCESSOR_CONF_TMP"
                    mv -f "$SUCCESSOR_CONF_TMP" "$SUCCESSOR_CONF"
                else
                    # Anomalous successor conf — no rule: line at all. Fall
                    # back to the today-shape full overwrite (loses any
                    # middleware/tls but at least the route works).
                    audit::log env-destroy successor-conf-shape-anomaly \
                        "$(jq -nc --arg slug "$SUCCESSOR_SLUG" \
                            '{successor_slug:$slug, msg:"no rule: Host(...) line found; full-overwrite fallback"}')"
                    cat > "$SUCCESSOR_CONF" <<EOF
# Generated by env-destroy (slot-rule re-registration) — do not hand-edit.
http:
  routers:
    env-${SUCCESSOR_SLUG}:
      rule: "${NEW_HOST_RULE}"
      service: env-${SUCCESSOR_SLUG}
      entryPoints: [web]
  services:
    env-${SUCCESSOR_SLUG}:
      loadBalancer:
        servers:
          - url: "http://${SUCCESSOR_APP_CONTAINER}:80"
EOF
                fi
                exec 9>&- 2>/dev/null || true
                audit::log env-destroy slot-rule-reassigned \
                    "$(jq -nc --arg from "$SLUG" --arg to "$SUCCESSOR_SLUG" --argjson slot "$DESTROYED_SLOT" \
                        '{from:$from, to:$to, slot:$slot}')"
            fi
        fi
    fi
fi
rm -f "$DESTROYED_CONF"

state::mutate "$RL_ENVS_FILE" --arg slug "$SLUG" 'map(select(.slug != $slug))'

# Test plan + attachments are NOT auto-cleaned on env-destroy anymore
# (operator pref 2026-05-19). Redeploys via destroy+spin should preserve
# tester progress; if the slug is truly being retired, the operator
# (or the agent's flow) calls rl_test_plan_clear explicitly. Keeps
# disk usage trivial — JSON + a handful of small screenshots per slug.

audit::log env-destroy ok "$(jq -nc --arg slug "$SLUG" --argjson force "$FORCE" '{slug:$slug, force:($force == 1)}')"
_perf_destroyed_slot="${DESTROYED_SLOT:-}"
[[ -z "$_perf_destroyed_slot" ]] && _perf_destroyed_slot="null"
[[ "$_perf_destroyed_slot" =~ ^[0-9]+$ ]] || _perf_destroyed_slot="null"
perf::end "env_destroy_total" "env.destroy.end" \
    "$(jq -nc --arg slug "$SLUG" --argjson slot "$_perf_destroyed_slot" '{slug:$slug, slot:$slot}')"
jq -nc --arg slug "$SLUG" '{ok: true, slug: $slug}'
