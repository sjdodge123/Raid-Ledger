{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@0.0.41",
        "--headless"
      ]
    },
    "mcp-env": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "tsx",
        "tools/mcp-env/src/index.ts"
      ],
      "env": {}
    },
    "mcp-discord": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "tsx",
        "tools/mcp-discord/src/index.ts"
      ],
      "env": {}
    }
  }
}
